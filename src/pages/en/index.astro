---
import { getCollection } from "astro:content";
import HomePage from "../../components/HomePage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const latestPosts = (await getCollection("blog", ({ id }) => id.startsWith("en/")))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title="Daniel Malmqvist | Architectural Engineer, BIM Manager, and Agentic Programmer"
  description="Architectural engineer and BIM manager in Tokyo working across digital twins, automation, and spatial-data implementation."
  image="/images/projects/shinjuku-nav-1-optimized.jpg"
  lang="en"
>
  <HomePage lang="en" latestPosts={latestPosts} />
</BaseLayout>
