---
import type { CollectionEntry } from "astro:content";
import BlogPostCard from "./BlogPostCard.astro";
import CTASection from "./CTASection.astro";
import ScrollReveal from "./ui/ScrollReveal.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
  allPosts: CollectionEntry<"blog">[];
}

const { lang, allPosts } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const copy = isJa
  ? {
      eyebrow: "WRITING",
      title: "記事",
      description:
        "建築、BIM、自動化、空間データの実装について書いています。単なる技術メモではなく、実務の現場で何が詰まり、どう設計し直すかを中心にした記録です。",
      filterAll: "すべて",
    }
  : {
      eyebrow: "WRITING",
      title: "Writing",
      description:
        "Notes on architecture, BIM, automation, and spatial-data implementation. The focus is not abstract trend commentary, but how technical decisions actually behave inside real projects.",
      filterAll: "All",
    };

const filterTags = [...new Set(allPosts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b),
);
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16 pt-20 md:pb-20">
  <SectionHeading eyebrow={copy.eyebrow} title={copy.title} description={copy.description} style={typeStyle} />
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-24">
  {
    filterTags.length > 1 && (
      <div class="flex flex-wrap gap-2" data-filter-chips role="group" aria-label={copy.eyebrow}>
        <button type="button" class="ui-pill-button is-active" data-filter-tag="" aria-pressed="true">
          {copy.filterAll}
        </button>
        {filterTags.map((tag) => (
          <button type="button" class="ui-pill-button" data-filter-tag={tag} aria-pressed="false">
            {tag}
          </button>
        ))}
      </div>
    )
  }

  <div class="mt-8 flex flex-col gap-3" data-filter-grid>
    {allPosts.map((post, index) => (
      <div data-filter-item data-post-tags={post.data.tags.join("|")}>
        <ScrollReveal variant="fade-up" delay={index * 90}>
          <BlogPostCard post={post} lang={lang} />
        </ScrollReveal>
      </div>
    ))}
  </div>

  <p class="mt-8 hidden text-center text-sm leading-7 text-[var(--color-text-secondary)]" data-filter-empty style={typeStyle}>
    {isJa ? "該当する記事がありません。" : "No posts match this tag."}
  </p>
</section>

<CTASection lang={lang} />

<script>
  function initBlogFilters() {
    const chipGroup = document.querySelector("[data-filter-chips]");
    const grid = document.querySelector("[data-filter-grid]");
    const emptyState = document.querySelector("[data-filter-empty]");
    if (!chipGroup || !grid) return;

    const chips = Array.from(chipGroup.querySelectorAll("[data-filter-tag]"));
    const items = Array.from(grid.querySelectorAll("[data-filter-item]"));

    chipGroup.addEventListener("click", (event) => {
      const chip = event.target && event.target.closest("[data-filter-tag]");
      if (!chip) return;

      const tag = chip.dataset.filterTag || "";
      chips.forEach((c) => {
        const active = c === chip;
        c.classList.toggle("is-active", active);
        c.setAttribute("aria-pressed", String(active));
      });

      let visibleCount = 0;
      items.forEach((item) => {
        const tags = (item.dataset.postTags || "").split("|");
        const matches = tag === "" || tags.includes(tag);
        item.classList.toggle("hidden", !matches);
        if (matches) visibleCount += 1;
      });
      if (emptyState) emptyState.classList.toggle("hidden", visibleCount > 0);
    });
  }

  initBlogFilters();
  document.addEventListener("astro:after-swap", initBlogFilters);
</script>
