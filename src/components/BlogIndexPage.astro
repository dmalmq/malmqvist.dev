---
import type { CollectionEntry } from "astro:content";
import BlogPostCard from "./BlogPostCard.astro";
import FadeIn from "./ui/FadeIn.astro";
import PageLead from "./ui/PageLead.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
  allPosts: CollectionEntry<"blog">[];
}

const { lang, allPosts } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const copy = isJa
  ? {
      eyebrow: "WRITING",
      title: "記事",
      description:
        "建築、BIM、自動化、空間データの実装について書いています。単なる技術メモではなく、実務の現場で何が詰まり、どう設計し直すかを中心にした記録です。",
    }
  : {
      eyebrow: "WRITING",
      title: "Writing",
      description:
        "Notes on architecture, BIM, automation, and spatial-data implementation. The focus is not abstract trend commentary, but how technical decisions actually behave inside real projects.",
    };
---

<section class="pb-6 pt-8 md:pt-12">
  <FadeIn>
    <PageLead
      eyebrow={copy.eyebrow}
      title={copy.title}
      description={copy.description}
      style={typeStyle}
    />
  </FadeIn>

  <div class="mt-8 space-y-3">
    {allPosts.map((post, index) => (
      <FadeIn delay={index * 110}>
        <BlogPostCard post={post} lang={lang} />
      </FadeIn>
    ))}
  </div>
</section>
