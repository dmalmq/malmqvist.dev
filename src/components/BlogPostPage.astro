---
import type { CollectionEntry } from "astro:content";
import type { Language } from "../i18n/utils";
import CTASection from "./CTASection.astro";
import FadeIn from "./ui/FadeIn.astro";
import Tag from "./ui/Tag.astro";

interface Props {
  lang: Language;
  post: CollectionEntry<"blog">;
  Content: any;
  nextPost?: CollectionEntry<"blog"> | null;
}

const { lang, post, Content, nextPost } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const formattedDate = new Intl.DateTimeFormat("en-CA", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(post.data.publishDate);

const metaLine = [formattedDate, post.data.readingTime?.toUpperCase(), "DANIEL MALMQVIST"]
  .filter(Boolean)
  .join(" · ");

const back = isJa ? "記事一覧に戻る" : "Back to writing";
const nextPostLabel = isJa ? "次の記事" : "NEXT POST";

const nextPostSlug = nextPost
  ? nextPost.id.split("/").pop()?.replace(/\.mdx?$/, "")
  : null;
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-6 pt-14 md:pt-18">
  <FadeIn>
    <a
      href={`/${lang}/blog`}
      class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-text-secondary)] transition-colors duration-300 hover:text-[var(--color-accent)]"
      style={typeStyle}
    >
      <span aria-hidden="true">←</span>
      {back}
    </a>
  </FadeIn>

  <FadeIn delay={40}>
    <div class="mt-6 flex flex-wrap gap-2">
      {post.data.tags.map((tag) => <Tag>{tag}</Tag>)}
    </div>
  </FadeIn>

  <FadeIn delay={80}>
    <h1
      class="mt-6 max-w-4xl text-[clamp(2rem,4.6vw,3rem)] font-semibold leading-[1.05] tracking-[-0.02em] text-[var(--color-text-heading)]"
      style={typeStyle}
    >
      {post.data.title}
    </h1>
  </FadeIn>

  <FadeIn delay={110}>
    <p class="mt-4 font-mono text-[0.75rem] font-medium tracking-[0.06em] text-[var(--color-text-secondary)]">
      {metaLine}
    </p>
  </FadeIn>
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16">
  <FadeIn delay={130}>
    <article class="editorial-prose max-w-[47.5rem]" style={typeStyle}>
      <Content />
    </article>
  </FadeIn>
</section>

{
  nextPost && nextPostSlug && (
    <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16">
      <FadeIn>
        <a
          href={`/${lang}/blog/${nextPostSlug}`}
          class="group flex items-center justify-between gap-6 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-8 py-8 transition-all duration-300 hover:border-[var(--color-border-hover)]"
        >
          <div>
            <p class="font-mono text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-secondary)]">
              {nextPostLabel}
            </p>
            <p
              class="mt-2 text-2xl font-semibold leading-tight tracking-[-0.01em] text-[var(--color-text-heading)] transition-colors group-hover:text-[var(--color-accent)]"
              style={typeStyle}
            >
              {nextPost.data.title}
            </p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--color-text-secondary)] transition-colors group-hover:text-[var(--color-accent)]" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </FadeIn>
    </section>
  )
}

<CTASection lang={lang} />
