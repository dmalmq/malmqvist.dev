---
import { getCollection } from "astro:content";
import HomePage from "../../components/HomePage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const latestPosts = (await getCollection("blog", ({ id }) => id.startsWith("en/")))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2);

const toolSlugs = ["en/revit-geopackage", "en/imdf-converter"];
const featuredTools = (await getCollection("projects", ({ id }) => toolSlugs.includes(id)))
  .sort((a, b) => toolSlugs.indexOf(a.id) - toolSlugs.indexOf(b.id));
---

<BaseLayout
  title="Daniel Malmqvist | Architectural Engineer & BIM Tools Developer"
  description="Architectural engineer in Tokyo writing Revit plugins, geospatial converters, and BIM data pipelines for digital twin work."
  image="/images/projects/shinjuku-nav-1-optimized.jpg"
  lang="en"
>
  <HomePage lang="en" latestPosts={latestPosts} featuredTools={featuredTools} />
</BaseLayout>
