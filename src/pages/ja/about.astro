---
import AboutPage from "../../components/AboutPage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

// SEO JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "ダニエル マルムクビスト (Daniel Malmqvist)",
  url: "https://malmqvist.dev/ja",
  image: "https://malmqvist.dev/images/projects/shinjuku-nav-1.png",
  jobTitle: "BIM Manager & Developer",
  worksFor: [
    {
      "@type": "Organization",
      name: "JRE Consultants",
    },
    {
      "@type": "Organization",
      name: "Tengbom",
    },
  ],
  sameAs: ["https://github.com/dmalmq", "https://linkedin.com/in/dmalmq"],
};
---

<BaseLayout title="概要 | Daniel Malmqvist" lang="ja">
  <!-- Schema.org Script -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <AboutPage lang="ja" />
</BaseLayout>
