---
import { getCollection } from "astro:content";
import HomePage from "../../components/HomePage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const latestPosts = (await getCollection("blog", ({ id }) => id.startsWith("ja/")))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title="Daniel Malmqvist | 建築エンジニア / BIMマネージャー / Agentic Programmer"
  description="東京を拠点に、デジタルツイン、自動化、空間データ実装に取り組む建築エンジニア / BIMマネージャーのポートフォリオ。"
  image="/images/projects/shinjuku-nav-1-optimized.jpg"
  lang="ja"
>
  <HomePage lang="ja" latestPosts={latestPosts} />
</BaseLayout>
