---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FadeIn from "../../../components/ui/FadeIn.astro";
import Tag from "../../../components/ui/Tag.astro";

export const prerender = true;

export async function getStaticPaths() {
    const projects = await getCollection("projects", ({ id }) =>
        id.startsWith("en/"),
    );
    return projects.map((p) => {
        const slugParts = p.id.split("/");
        const basename = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
        return {
            params: { slug: basename },
            props: { project: p },
        };
    });
}

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Projects`} lang="en">
    <article class="py-16 md:py-24 max-w-4xl mx-auto px-4">
        <FadeIn>
            <a
                href="/en/projects"
                class="inline-flex items-center text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors mb-8"
            >
                ← Back to Projects
            </a>
            <h1
                class="text-4xl md:text-5xl font-black text-[var(--color-text-heading)] mb-6"
            >
                {project.data.title}
            </h1>
            <p
                class="text-xl md:text-2xl text-[var(--color-text-secondary)] mb-8 font-medium"
            >
                {project.data.description}
            </p>

            <div
                class="flex flex-wrap gap-2 mb-12 pb-8 border-b border-[var(--color-border)]"
            >
                {project.data.tags.map((tag: string) => <Tag>{tag}</Tag>)}
            </div>
        </FadeIn>

        {
            project.data.coverImage && (
                <FadeIn delay={100}>
                    <div
                        class="w-full aspect-video rounded-[8px] md:rounded-[12px] overflow-hidden border border-[var(--color-border)] mb-16 relative group cursor-pointer"
                        id="main-image"
                    >
                        <img
                            src={project.data.coverImage}
                            alt={project.data.title}
                            class="w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-[var(--color-bg-primary)]/0 group-hover:bg-[var(--color-bg-primary)]/20 transition-all flex items-center justify-center pointer-events-none">
                            <span class="opacity-0 group-hover:opacity-100 bg-[var(--color-bg-elevated)] text-[var(--color-text-heading)] px-4 py-2 rounded-full shadow-lg font-medium text-sm transition-opacity">
                                Click to preview
                            </span>
                        </div>
                    </div>
                </FadeIn>
            )
        }

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div
                class="md:col-span-1 space-y-10 border-r-0 md:border-r md:border-[var(--color-border)] pr-0 md:pr-8"
            >
                <FadeIn delay={200}>
                    <h3
                        class="text-sm font-bold text-[var(--color-text-heading)] uppercase tracking-wider mb-3"
                    >
                        Tech Stack
                    </h3>
                    <ul
                        class="space-y-2 text-[var(--color-text-secondary)] list-none pl-0"
                    >
                        {
                            project.data.techStack?.map((tech: string) => (
                                <li class="flex items-center">
                                    <span class="text-[var(--color-accent)] mr-2">
                                        ▹
                                    </span>{" "}
                                    {tech}
                                </li>
                            ))
                        }
                    </ul>
                </FadeIn>

                {
                    project.data.impact && (
                        <FadeIn delay={300}>
                            <h3 class="text-sm font-bold text-[var(--color-text-heading)] uppercase tracking-wider mb-3">
                                Impact
                            </h3>
                            <p class="text-[var(--color-text-primary)] font-medium text-base bg-[var(--color-bg-secondary)] border border-[var(--color-border)] p-4 rounded-[6px]">
                                {project.data.impact}
                            </p>
                        </FadeIn>
                    )
                }
            </div>

            <div
                class="md:col-span-2 prose prose-lg dark:prose-invert max-w-none prose-headings:text-[var(--color-text-heading)] prose-a:text-[var(--color-accent)] hover:prose-a:text-[var(--color-accent-hover)] prose-code:bg-[var(--color-code-bg)] prose-code:text-[var(--color-code-text)] text-[var(--color-text-secondary)]"
            >
                {
                    project.data.problem && (
                        <FadeIn delay={200}>
                            <h2>The Problem</h2>
                            <p>{project.data.problem}</p>
                        </FadeIn>
                    )
                }

                {
                    project.data.solution && (
                        <FadeIn delay={300}>
                            <h2>The Solution</h2>
                            <p>{project.data.solution}</p>
                        </FadeIn>
                    )
                }

                <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
                    <Content />
                </div>
            </div>
        </div>
    </article>

    {/* A very rudimentary lightbox trigger script */}
    <script>
        const el = document.getElementById("main-image");
        if (el) {
            el.addEventListener("click", () => {
                const bgImg = el.querySelector("img")?.src;
                if (bgImg) {
                    window.dispatchEvent(
                        new CustomEvent("open-lightbox", {
                            detail: { src: bgImg },
                        }),
                    );
                }
            });
        }
    </script>
</BaseLayout>
