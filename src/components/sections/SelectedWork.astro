---
import { getCollection } from "astro:content";
import Reveal from "../animation/Reveal.astro";
import ResponsivePicture from "../ResponsivePicture.astro";
import { Badge } from "../ui/badge";
import { Card } from "../ui/card";
import { useTranslations, type Language } from "../../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const projects = (await getCollection("projects", (entry) => entry.id.startsWith(`${lang}/`) && entry.data.featured))
  .sort((a, b) =>
    (a.data.featuredRank ?? Number.MAX_SAFE_INTEGER) - (b.data.featuredRank ?? Number.MAX_SAFE_INTEGER) ||
    b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<section class="container border-t border-[var(--line)] py-[clamp(4rem,8vw,8rem)]" aria-labelledby="selected-work-title">
  <Reveal>
    <h2 id="selected-work-title" class="text-[length:var(--font-h2)]">
      {t("home.selected.title")}
    </h2>
  </Reveal>

  <div class="mt-12 space-y-12">
    {projects.map((project, index) => {
      const slug = project.id.replace(`${lang}/`, "");
      const lead = index === 0;
      return (
        <Reveal delay={index * 150}>
          <div class="project-card featured">
            <a href={`/${lang}/projects/${slug}/`} class="group block focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]">
              <Card
                className={`overflow-hidden py-0 transition-colors group-hover:border-[var(--accent)] ${
                  lead ? "" : "md:grid md:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]"
                }`}
              >
                <div class="bg-[var(--surface-soft)]">
                  {project.data.coverImage && (
                    <ResponsivePicture
                      src={project.data.coverImage}
                      alt={project.data.title}
                      aspect="wide"
                      sizes={lead ? "(min-width: 1440px) 84rem, 96vw" : "(min-width: 1024px) 42rem, 100vw"}
                      class={lead ? "aspect-[21/9] w-full object-cover" : "aspect-[16/10] h-full w-full object-cover"}
                    />
                  )}
                </div>
                <div class={lead ? "grid gap-6 p-6 md:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)] md:p-8" : "flex min-h-80 flex-col justify-between p-6 md:p-8"}>
                  <div>
                    {project.data.role && (
                      <p class="font-mono text-xs leading-5 text-[var(--text-muted)]">
                        {project.data.role}
                      </p>
                    )}
                    <h3 class="mt-3 text-[length:var(--font-h3)] leading-tight text-[var(--text)]">
                      {project.data.title}
                    </h3>
                  </div>
                  <div class={lead ? "" : "mt-4"}>
                    <p class="max-w-[65ch] text-base leading-8 text-[var(--text-muted)]">
                      {project.data.description}
                    </p>
                    {project.data.impact && (
                      <p class="mt-3 max-w-[65ch] border-t border-[var(--line)] pt-3 text-sm font-semibold leading-6 text-[var(--text)]">
                        {project.data.impact}
                      </p>
                    )}
                    <div class="mt-6 flex flex-wrap gap-2">
                      {project.data.tags.slice(0, 5).map((tag) => <Badge>{tag}</Badge>)}
                    </div>
                  </div>
                </div>
              </Card>
            </a>
          </div>
        </Reveal>
      );
    })}
  </div>
</section>
