---
// Root index: Handle language redirection based on preferred or navigator logic.
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daniel Malmqvist | Portfolio</title>
    
    <script is:inline>
      const storedLang = localStorage.getItem('preferred-language');
      
      if (storedLang) {
        window.location.replace(`/${storedLang}/`);
      } else {
        const browserLang = navigator.language;
        if (browserLang && browserLang.startsWith('ja')) {
          window.location.replace('/ja/');
        } else {
          window.location.replace('/en/');
        }
      }
    </script>
  </head>
  <body>
    {/* Fallbacks if JS disabled */}
    <div style="padding: 2rem;">
      <p>Please select your language:</p>
      <a href="/en/">English</a> | <a href="/ja/">日本語</a>
    </div>
  </body>
</html>
