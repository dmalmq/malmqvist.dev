---
import { getCollection } from "astro:content";
import BlogIndexPage from "../../../components/BlogIndexPage.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const allPosts = await getCollection("blog", ({ id }) => {
    return id.startsWith("en/");
});

allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const shareImage = allPosts[0]?.data.coverImage ?? "/images/projects/shinjuku-nav-1.png";
---

<BaseLayout
    title="Blog | Daniel Malmqvist"
    description="Writing on BIM, automation, architectural engineering, and spatial-data implementation."
    image={shareImage}
    lang="en"
>
    <BlogIndexPage lang="en" allPosts={allPosts} />
</BaseLayout>
