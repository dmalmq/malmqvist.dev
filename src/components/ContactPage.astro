---
import SocialLinks from "./SocialLinks.astro";
import ContactForm from "./ContactForm";
import FadeIn from "./ui/FadeIn.astro";
import ScrollReveal from "./ui/ScrollReveal.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const copy = isJa
  ? {
      eyebrow: "CONTACT",
      title: "お話しましょう。",
      description:
        "建築、BIM、自動化、空間データの実装についてのご相談を受け付けています。通常、数日以内に返信します。",
      directTitle: "DIRECT",
      directNote: "東京在住（JST, UTC+9）。通常、数日以内に返信します。",
    }
  : {
      eyebrow: "CONTACT",
      title: "Let's build something together.",
      description:
        "Available for architecture, BIM, automation, and spatial-data collaborations. I usually reply within a few days.",
      directTitle: "DIRECT",
      directNote: "Based in Tokyo (JST, UTC+9). I usually reply within a few days.",
    };
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16 pt-20 md:pb-20">
  <FadeIn>
    <SectionHeading eyebrow={copy.eyebrow} title={copy.title} description={copy.description} style={typeStyle} />
  </FadeIn>
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-24">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_25rem]">
    <ScrollReveal variant="fade-up">
      <div style={typeStyle}>
        <ContactForm lang={lang} client:load />
      </div>
    </ScrollReveal>

    <ScrollReveal variant="fade-up" delay={80}>
      <div class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-8">
        <p class="font-mono text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-secondary)]">
          {copy.directTitle}
        </p>
        <a
          href="mailto:daniel@malmqvist.dev"
          class="mt-4 block text-xl font-semibold text-[var(--color-accent)] transition-colors hover:text-[var(--color-accent-hover)]"
        >
          daniel@malmqvist.dev
        </a>
        <p class="mt-4 text-sm leading-6 text-[var(--color-text-secondary)]" style={typeStyle}>
          {copy.directNote}
        </p>
        <div class="mt-6">
          <SocialLinks variant="bare" />
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
