---
import Reveal from "./animation/Reveal.astro";
import ProfileCard from "./sections/ProfileCard.astro";
import SkillsGrid from "./SkillsGrid.astro";
import Timeline from "./Timeline.astro";
import { Card } from "./ui/card";
import { useTranslations, type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const copy = {
  en: {
    description: "I work where architectural intent, BIM practice, and automation meet. The consistent thread is translating complex spatial information into systems that can actually be used.",
    narrativeTitle: "Background",
    paragraphs: [
      "My work spans the path from traditional architectural production in Sweden to city-scale digital twin work in Tokyo. The core interest has stayed the same: how space is described, coordinated, and made operational.",
      "At Tengbom, I worked on award-winning healthcare and airport projects, not as a passive file coordinator but as someone rebuilding living BIM models, coordinating complex facade systems, and resolving interdisciplinary issues under real delivery pressure.",
      "Over time, the limits of legacy AEC tooling became too obvious to ignore. That pushed me toward writing code, building conversion pipelines, and treating BIM information as something that should move cleanly into broader spatial systems instead of getting trapped in brittle intermediate steps.",
    ],
    quote: "The strongest BIM systems are built by people who understand both the discipline-specific design intent and the technical pipeline required to deploy it.",
    timelineTitle: "Experience",
    timelineDesc: "The trajectory runs from BIM-heavy architectural practice in Stockholm to digital-twin implementation work in Tokyo.",
  },
  ja: {
    description: "建築の設計意図、BIMの実務、そして自動化をつなぐ仕事をしています。空間データを正しく理解し、運用可能なシステムに変換することが自分の役割です。",
    narrativeTitle: "Background",
    paragraphs: [
      "スウェーデンでの伝統的な建築実務から、現在の東京における都市スケールのデジタルツインまで、一貫して空間をどう構成し、どう扱うかを仕事にしてきました。",
      "Tengbomでは受賞歴のある病院建築や空港拡張に携わり、単なるファイル管理ではなく、実際に施工へつながるBIMモデルの再構築、ファサード調整、他分野との衝突解消を担いました。",
      "その後、既存のAECツールだけでは処理しきれない課題に対して、自分でコードを書き、データ変換や自動化のパイプラインを組む方向へ進みました。今は東京で、建築のネイティブな情報を空間システムへ直接つなげる実装に取り組んでいます。",
    ],
    quote: "建築家の意図する緻密な空間と、実装のための技術的データパイプライン。その両方を理解することが、良いBIMシステムの前提だと考えています。",
    timelineTitle: "職歴",
    timelineDesc: "建築事務所でのBIM実務から、東京でのデジタルツイン開発へと軸足を移してきました。",
  },
  sv: {
    description: "Jag arbetar där arkitektonisk avsikt, BIM-praktik och automation möts. Den röda tråden är att översätta komplex rumslig information till system som faktiskt går att använda.",
    narrativeTitle: "Bakgrund",
    paragraphs: [
      "Mitt arbete spänner från traditionell arkitekturproduktion i Sverige till digitala tvillingar i stadsskala i Tokyo. Kärnintresset har varit detsamma: hur rum beskrivs, samordnas och görs operativa.",
      "På Tengbom arbetade jag med prisbelönta vård- och flygplatsprojekt — inte som passiv filhanterare, utan med att bygga levande BIM-modeller, samordna komplexa fasadsystem och lösa tvärdisciplinära frågor under verkligt leveranstryck.",
      "Med tiden blev begränsningarna i äldre AEC-verktyg omöjliga att blunda för. Det drev mig mot att skriva kod, bygga konverteringspipelines och behandla BIM-information som något som ska kunna röra sig rent in i bredare spatiala system — i stället för att fastna i sköra mellansteg.",
    ],
    quote: "De starkaste BIM-systemen byggs av personer som förstår både den disciplinspecifika designavsikten och den tekniska pipeline som krävs för att sätta den i drift.",
    timelineTitle: "Erfarenhet",
    timelineDesc: "Banan går från BIM-tung arkitekturpraktik i Stockholm till implementering av digitala tvillingar i Tokyo.",
  },
}[lang];
---

<div class="bg-[var(--bg)] text-[var(--text)]">
  <section class="container py-[clamp(4rem,8vw,8rem)]">
    <Reveal>
      <p class="text-[length:var(--font-meta)] font-bold uppercase tracking-[0.28em] text-[var(--text-muted)]">
        {t("about.title")}
      </p>
      <h1 class="mt-4 max-w-5xl text-[length:var(--font-hero)] font-bold tracking-[-0.06em]">
        Daniel Malmqvist
      </h1>
      <p class="mt-6 max-w-3xl text-[length:var(--font-body)] leading-8 text-[var(--text-muted)]">
        {copy.description}
      </p>
    </Reveal>

    <Reveal delay={120}>
      <Card className="mt-10 p-6 md:p-8">
        <p class="text-[length:var(--font-meta)] font-bold uppercase tracking-[0.28em] text-[var(--text-muted)]">
          {copy.narrativeTitle}
        </p>
        <div class="mt-5 space-y-5">
          {copy.paragraphs.map((paragraph) => <p class="max-w-4xl text-base leading-8 text-[var(--text-muted)] md:text-lg">{paragraph}</p>)}
        </div>
        <blockquote class="mt-6 border-l border-[var(--accent)] pl-5 text-base leading-8 text-[var(--text)]">
          {copy.quote}
        </blockquote>
      </Card>
    </Reveal>
  </section>

  <section class="container py-[clamp(4rem,8vw,8rem)]" aria-labelledby="timeline-title">
    <Reveal>
      <p class="text-[length:var(--font-meta)] font-bold uppercase tracking-[0.28em] text-[var(--text-muted)]">Experience</p>
      <h2 id="timeline-title" class="mt-3 text-[length:var(--font-h2)] font-bold tracking-[-0.05em]">{copy.timelineTitle}</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[var(--text-muted)]">{copy.timelineDesc}</p>
    </Reveal>
    <div class="mt-10">
      <Timeline lang={lang} />
    </div>
  </section>

  <section class="container py-[clamp(4rem,8vw,8rem)]" aria-labelledby="skills-title">
    <Reveal>
      <p class="text-[length:var(--font-meta)] font-bold uppercase tracking-[0.28em] text-[var(--text-muted)]">Skills</p>
      <h2 id="skills-title" class="mt-3 text-[length:var(--font-h2)] font-bold tracking-[-0.05em]">{t("home.skills.title")}</h2>
    </Reveal>
    <div class="mt-10">
      <SkillsGrid lang={lang} />
    </div>
  </section>

  <section class="container py-[clamp(4rem,8vw,8rem)]">
    <Reveal>
      <ProfileCard lang={lang} />
    </Reveal>
  </section>
</div>
