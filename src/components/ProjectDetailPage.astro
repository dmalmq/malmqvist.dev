---
import type { CollectionEntry } from "astro:content";
import type { Language } from "../i18n/utils";
import Button from "./ui/Button.astro";
import FadeIn from "./ui/FadeIn.astro";
import ProjectCard from "./ProjectCard.astro";
import Tag from "./ui/Tag.astro";

interface Props {
  lang: Language;
  project: CollectionEntry<"projects">;
  Content: any;
  relatedProjects: CollectionEntry<"projects">[];
}

const { lang, project, Content, relatedProjects } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;
const mediaScopeId = `project-media-${project.id.replaceAll("/", "-")}`;
const galleryImages = Array.from(
  new Set([project.data.coverImage, ...project.data.galleryImages].filter(Boolean)),
);
const featuredImage = galleryImages[0];
const secondaryGallery = galleryImages.slice(1);
const formattedDate = new Intl.DateTimeFormat(isJa ? "ja-JP" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(project.data.publishDate);

const overviewCards = [
  project.data.problem && {
    label: isJa ? "課題" : "Challenge",
    value: project.data.problem,
  },
  project.data.solution && {
    label: isJa ? "アプローチ" : "Approach",
    value: project.data.solution,
  },
  project.data.impact && {
    label: isJa ? "成果" : "Outcome",
    value: project.data.impact,
  },
].filter(Boolean);

const copy = isJa
  ? {
      eyebrow: project.data.featured ? "FEATURED CASE" : "CASE STUDY",
      back: "プロジェクト一覧に戻る",
      lead:
        "建築・BIM・空間データの文脈の中で、どの課題をどう実装したかをまとめたケーススタディです。",
      metaTitle: "プロジェクト概要",
      metaNote:
        "実装の中で重視したのは、建築的な意味を失わずに運用可能なデータへ変換することです。",
      metaItems: [
        { label: "公開日", value: formattedDate },
        {
          label: "主な領域",
          value:
            project.data.tags.slice(0, 3).join(" / ") || "Architecture / BIM",
        },
        {
          label: "技術要素",
          value:
            project.data.techStack.length > 0
              ? `${project.data.techStack.length} 項目`
              : "整理中",
        },
      ],
      preview: "クリックして拡大",
      galleryTitle: "ギャラリー",
      galleryNote: "ツール画面や出力ワークフローの追加ビューです。",
      bodyEyebrow: "IMPLEMENTATION NOTES",
      bodyTitle: "実装の詳細",
      bodyDescription:
        "ケースの背景だけでなく、実際に何を作り、どのような変換や判断を行ったかに焦点を当てています。",
      stackTitle: "使用技術",
      stackEmpty: "技術スタックは後日追記予定です。",
      stackNote:
        "各ツールは単独で使うのではなく、モデルから運用可能なデータを取り出すための連携として扱っています。",
      nextTitle: "次の導線",
      nextDescription:
        "似たテーマの案件や、自動化・BIM・空間データの相談については以下からどうぞ。",
      primaryCta: "問い合わせる",
      secondaryCta: "他のプロジェクトを見る",
      relatedEyebrow: "RELATED WORK",
      relatedTitle: "関連プロジェクト",
      relatedDescription:
        "扱う粒度は違っても、空間情報を使える形に変えるという点でつながっている案件です。",
    }
  : {
      eyebrow: project.data.featured ? "FEATURED CASE" : "CASE STUDY",
      back: "Back to projects",
      lead:
        "A case study focused on how architectural, BIM, and spatial-data problems were framed and then translated into implementation.",
      metaTitle: "Project profile",
      metaNote:
        "The throughline is preserving architectural meaning while turning the source material into data that can actually be used downstream.",
      metaItems: [
        { label: "Published", value: formattedDate },
        {
          label: "Primary domains",
          value:
            project.data.tags.slice(0, 3).join(" / ") || "Architecture / BIM",
        },
        {
          label: "Technical layers",
          value:
            project.data.techStack.length > 0
              ? `${project.data.techStack.length} tools`
              : "TBD",
        },
      ],
      preview: "Click to preview",
      galleryTitle: "Gallery",
      galleryNote: "Additional views from the tool and export workflow.",
      bodyEyebrow: "IMPLEMENTATION NOTES",
      bodyTitle: "How the work was structured",
      bodyDescription:
        "The emphasis is on what had to be built, translated, or coordinated to make the project usable in practice.",
      stackTitle: "Working stack",
      stackEmpty: "The stack details will be added later.",
      stackNote:
        "These tools matter less as a list than as a chain: model, transform, validate, and hand off usable information.",
      nextTitle: "Continue from here",
      nextDescription:
        "For adjacent work or a direct conversation about BIM, automation, or spatial-data implementation, use the links below.",
      primaryCta: "Get in touch",
      secondaryCta: "See more projects",
      relatedEyebrow: "RELATED WORK",
      relatedTitle: "More project context",
      relatedDescription:
        "Different scales, same pattern: turn difficult spatial information into something precise, usable, and maintainable.",
    };
---

<section class="pb-6 pt-8 md:pt-12">
  <FadeIn>
    <a
      href={`/${lang}/projects`}
      class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-text-secondary)] transition-colors duration-300 hover:text-[var(--color-accent)]"
      style={typeStyle}
    >
      <span aria-hidden="true">←</span>
      {copy.back}
    </a>
  </FadeIn>

  <div class="mt-8 grid gap-8 xl:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.62fr)] xl:items-end">
    <div class="max-w-4xl">
      <FadeIn delay={40}>
        <p class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
          {copy.eyebrow}
        </p>
      </FadeIn>

      <FadeIn delay={90}>
        <h1
          class="mt-6 text-[clamp(3.2rem,8vw,6.2rem)] font-semibold leading-[0.9] tracking-[-0.07em] text-[var(--color-text-heading)]"
          style={typeStyle}
        >
          {project.data.title}
        </h1>
        <p
          class="mt-6 max-w-3xl text-xl leading-8 text-[var(--color-text-heading)] md:text-2xl"
          style={typeStyle}
        >
          {project.data.description}
        </p>
        <p
          class="mt-5 max-w-3xl text-base leading-8 text-[var(--color-text-secondary)] md:text-lg"
          style={typeStyle}
        >
          {copy.lead}
        </p>
      </FadeIn>

      <FadeIn delay={140}>
        <div class="mt-8 flex flex-wrap gap-2">
          {project.data.tags.map((tag) => <Tag>{tag}</Tag>)}
        </div>
      </FadeIn>
    </div>

    <FadeIn delay={130}>
      <div class="rounded-[1.6rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 shadow-[0_28px_70px_-48px_rgba(87,82,121,0.42)] dark:shadow-[0_28px_70px_-48px_rgba(25,23,36,0.95)] md:p-7">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
          {copy.metaTitle}
        </p>
        <dl class="mt-5 space-y-4">
          {
            copy.metaItems.map((item) => (
              <div class="border-b border-[var(--color-border)] pb-4 last:border-b-0 last:pb-0">
                <dt class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-secondary)]">
                  {item.label}
                </dt>
                <dd class="mt-2 text-sm leading-6 text-[var(--color-text-heading)] md:text-base" style={typeStyle}>
                  {item.value}
                </dd>
              </div>
            ))
          }
        </dl>
        <p class="mt-5 border-l border-[var(--color-border)] pl-4 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
          {copy.metaNote}
        </p>
      </div>
    </FadeIn>
  </div>
</section>

{
  featuredImage && (
    <section id={mediaScopeId} class="border-t border-[var(--color-border)] pt-16 md:pt-20">
      <FadeIn>
        <div
          data-lightbox-src={featuredImage}
          class="group relative overflow-hidden rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-bg-secondary)] shadow-[0_34px_90px_-56px_rgba(87,82,121,0.45)]"
        >
          <img
            src={featuredImage}
            alt={project.data.title}
            decoding="async"
            class="aspect-[16/9] w-full object-cover transition-transform duration-500 group-hover:scale-[1.015]"
          />
          <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-4 border-t border-[var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-bg-primary)_78%,transparent)] px-5 py-4 backdrop-blur-md md:px-6">
            <div class="flex flex-wrap gap-2">
              {project.data.tags.slice(0, 3).map((tag) => <Tag>{tag}</Tag>)}
            </div>
            <span
              class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-secondary)]"
              style={typeStyle}
            >
              {copy.preview}
            </span>
          </div>
        </div>
      </FadeIn>

      {
        secondaryGallery.length > 0 && (
          <FadeIn delay={90}>
            <div class="mt-6 rounded-[1.75rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5 shadow-[0_22px_62px_-46px_rgba(87,82,121,0.36)] dark:shadow-[0_22px_62px_-46px_rgba(25,23,36,0.95)] md:p-6">
              <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                <div>
                  <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
                    {copy.galleryTitle}
                  </p>
                  <p class="mt-2 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
                    {copy.galleryNote}
                  </p>
                </div>
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-secondary)]" style={typeStyle}>
                  {copy.preview}
                </p>
              </div>

              <div class:list={["grid gap-4", secondaryGallery.length > 1 ? "md:grid-cols-2" : "md:grid-cols-1"]}>
                {secondaryGallery.map((image, index) => (
                  <button
                    type="button"
                    data-lightbox-src={image}
                    class="group relative overflow-hidden rounded-[1.35rem] border border-[var(--color-border)] bg-[var(--color-bg-secondary)] text-left shadow-[0_18px_48px_-42px_rgba(87,82,121,0.34)] transition-all duration-300 hover:-translate-y-0.5 hover:border-[var(--color-border-hover)] hover:shadow-[0_26px_60px_-44px_rgba(87,82,121,0.42)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ring)] focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-bg-primary)]"
                  >
                    <img
                      src={image}
                      alt={`${project.data.title} detail view ${index + 2}`}
                      loading="lazy"
                      decoding="async"
                      class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    />
                    <div class="absolute inset-x-0 bottom-0 border-t border-[var(--color-border)] bg-[color:color-mix(in_srgb,var(--color-bg-primary)_82%,transparent)] px-4 py-3 backdrop-blur-md">
                      <span class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-secondary)]" style={typeStyle}>
                        {copy.preview}
                      </span>
                    </div>
                  </button>
                ))}
              </div>
            </div>
          </FadeIn>
        )
      }
    </section>
  )
}

{
  overviewCards.length > 0 && (
    <section class="border-t border-[var(--color-border)] pt-16 md:pt-20">
      <div class="grid gap-5 lg:grid-cols-3">
        {overviewCards.map((item, index) => (
          <FadeIn delay={index * 90}>
            <div class="rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 shadow-[0_22px_62px_-46px_rgba(87,82,121,0.36)] dark:shadow-[0_22px_62px_-46px_rgba(25,23,36,0.95)] md:p-7">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
                {item.label}
              </p>
              <p class="mt-4 text-sm leading-7 text-[var(--color-text-heading)] md:text-base" style={typeStyle}>
                {item.value}
              </p>
            </div>
          </FadeIn>
        ))}
      </div>
    </section>
  )
}

<section class="border-t border-[var(--color-border)] pt-20 md:pt-24">
  <div class="grid gap-8 xl:grid-cols-[minmax(0,1.08fr)_minmax(18rem,0.52fr)]">
    <div>
      <FadeIn>
        <div class="max-w-3xl">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
            {copy.bodyEyebrow}
          </p>
          <h2
            class="mt-5 text-[clamp(2.2rem,5vw,3.9rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-[var(--color-text-heading)]"
            style={typeStyle}
          >
            {copy.bodyTitle}
          </h2>
          <p class="mt-5 text-base leading-8 text-[var(--color-text-secondary)] md:text-lg" style={typeStyle}>
            {copy.bodyDescription}
          </p>
        </div>
      </FadeIn>

      <FadeIn delay={90}>
        <div class="mt-10 rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-7 shadow-[0_34px_90px_-56px_rgba(87,82,121,0.45)] dark:shadow-[0_34px_90px_-56px_rgba(25,23,36,0.98)] md:p-10">
          <article class="editorial-prose" style={typeStyle}>
            <Content />
          </article>
        </div>
      </FadeIn>
    </div>

    <div class="space-y-6 xl:sticky xl:top-28 self-start">
      <FadeIn delay={130}>
        <div class="rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 shadow-[0_22px_62px_-46px_rgba(87,82,121,0.36)] dark:shadow-[0_22px_62px_-46px_rgba(25,23,36,0.95)] md:p-7">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            {copy.stackTitle}
          </p>
          {
            project.data.techStack.length > 0 ? (
              <div class="mt-5 flex flex-wrap gap-2">
                {project.data.techStack.map((tech) => <Tag>{tech}</Tag>)}
              </div>
            ) : (
              <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
                {copy.stackEmpty}
              </p>
            )
          }
          <p class="mt-5 border-l border-[var(--color-border)] pl-4 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
            {copy.stackNote}
          </p>
        </div>
      </FadeIn>

      <FadeIn delay={180}>
        <div class="rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 shadow-[0_18px_48px_-42px_rgba(87,82,121,0.34)] dark:shadow-[0_18px_48px_-42px_rgba(25,23,36,0.95)] md:p-7">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            {copy.nextTitle}
          </p>
          <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
            {copy.nextDescription}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <Button href={`/${lang}/contact`} variant="primary">
              {copy.primaryCta}
            </Button>
            <Button href={`/${lang}/projects`} variant="secondary">
              {copy.secondaryCta}
            </Button>
          </div>
        </div>
      </FadeIn>
    </div>
  </div>
</section>

{
  relatedProjects.length > 0 && (
    <section class="border-t border-[var(--color-border)] pt-24 md:pt-32">
      <FadeIn>
        <div class="max-w-3xl">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
            {copy.relatedEyebrow}
          </p>
          <h2
            class="mt-5 text-[clamp(2.2rem,5vw,3.8rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-[var(--color-text-heading)]"
            style={typeStyle}
          >
            {copy.relatedTitle}
          </h2>
          <p class="mt-5 text-base leading-8 text-[var(--color-text-secondary)] md:text-lg" style={typeStyle}>
            {copy.relatedDescription}
          </p>
        </div>
      </FadeIn>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {relatedProjects.map((relatedProject, index) => (
          <FadeIn delay={index * 110}>
            <ProjectCard project={relatedProject} lang={lang} />
          </FadeIn>
        ))}
      </div>
    </section>
  )
}

<script define:vars={{ mediaScopeId }}>
  const mediaScope = document.getElementById(mediaScopeId);
  if (mediaScope) {
    mediaScope.querySelectorAll("[data-lightbox-src]").forEach((node) => {
      node.addEventListener("click", () => {
        const src = node.getAttribute("data-lightbox-src");
        if (src) {
          window.dispatchEvent(
            new CustomEvent("open-lightbox", {
              detail: { src },
            }),
          );
        }
      });
    });
  }
</script>
