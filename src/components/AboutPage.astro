---
import CTASection from "./CTASection.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import SkillsGrid from "./SkillsGrid.astro";
import Timeline from "./Timeline.astro";
import { useTranslations, type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;
const t = useTranslations(lang);

const copy = isJa
  ? {
      eyebrow: "ABOUT",
      title: t("about.title"),
      description:
        "スウェーデンで建築家としてキャリアを始め、7年間、病院や空港インフラのBIMマネジメントに従事した後、東京へ拠点を移し、日本のデジタルツインの屋内レイヤーを構築しています。現在は家族とともに東京在住です。",
      careerEyebrow: "CAREER",
      quote:
        "優れたBIMソリューションは、設計意図とデータパイプラインの両方を理解している人から生まれます。ソフトウェアの操作だけでは足りません。",
      skillsEyebrow: "SKILLS",
      skillsTitle: "使いこなしている技術",
    }
  : {
      eyebrow: "ABOUT",
      title: t("about.title"),
      description:
        "I started as an architect in Stockholm, spent seven years in BIM management on hospitals and airport infrastructure, then moved to Tokyo to build the indoor layer of Japan's digital twin. I'm based in Tokyo with my family.",
      careerEyebrow: "CAREER",
      quote:
        "The best BIM solutions come from people who understand both the design intent and the data pipeline — not just the software.",
      skillsEyebrow: "SKILLS",
      skillsTitle: "Tools of the trade",
    };
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16 pt-20 md:pb-20">
  <SectionHeading eyebrow={copy.eyebrow} title={copy.title} description={copy.description} style={typeStyle} />
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-24">
  <p class="font-mono text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-accent)]">
    {copy.careerEyebrow}
  </p>
  <div class="mt-8 max-w-[50rem]">
    <Timeline lang={lang} />
  </div>
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-24">
  <div class="flex gap-8 border-l-[3px] border-[var(--color-accent)] pl-8">
    <p class="max-w-3xl text-[1.5rem] font-semibold leading-[1.35] text-[var(--color-text-heading)]" style={typeStyle}>
      {copy.quote}
    </p>
  </div>
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-24">
  <SectionHeading eyebrow={copy.skillsEyebrow} title={copy.skillsTitle} style={typeStyle} />
  <div class="mt-10">
    <SkillsGrid lang={lang} />
  </div>
</section>

<CTASection lang={lang} />
