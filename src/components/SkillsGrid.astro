---
import Reveal from "./animation/Reveal.astro";
import { Badge } from "./ui/badge";
import { Card } from "./ui/card";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const categories = {
  en: [
    { name: "Architecture & BIM", skills: ["Revit", "ArchiCAD", "BIM coordination", "clash detection"] },
    { name: "Geospatial", skills: ["CityGML", "IFC", "GeoPackage", "IMDF", "Shapefiles"] },
    { name: "Open-source", skills: ["Blender", "Bonsai"] },
    { name: "Programming", skills: ["Python", "C#"] },
    { name: "Visualization", skills: ["FBX", "Unity", "Blender renders"] },
    { name: "Languages", skills: ["English native", "Swedish native", "Japanese JLPT N3 / N2 in progress"] },
  ],
  ja: [
    { name: "建築・BIM", skills: ["Revit", "ArchiCAD", "BIM coordination", "Clash detection"] },
    { name: "地理空間", skills: ["CityGML", "IFC", "GeoPackage", "IMDF", "Shapefiles"] },
    { name: "オープンソース", skills: ["Blender", "Bonsai"] },
    { name: "プログラミング", skills: ["Python", "C#"] },
    { name: "ビジュアライゼーション", skills: ["FBX", "Unity", "Blender renders"] },
    { name: "言語", skills: ["英語 native", "スウェーデン語 native", "日本語 JLPT N3 / N2勉強中"] },
  ],
  sv: [
    { name: "Arkitektur & BIM", skills: ["Revit", "ArchiCAD", "BIM coordination", "clash detection"] },
    { name: "Geospatial", skills: ["CityGML", "IFC", "GeoPackage", "IMDF", "Shapefiles"] },
    { name: "Öppen källkod", skills: ["Blender", "Bonsai"] },
    { name: "Programmering", skills: ["Python", "C#"] },
    { name: "Visualisering", skills: ["FBX", "Unity", "Blender renders"] },
    { name: "Språk", skills: ["English native", "Swedish native", "Japanese JLPT N3 / N2 in progress"] },
  ],
}[lang];
---

<div class="grid gap-4 md:grid-cols-2">
  {categories.map((category, index) => (
    <Reveal delay={index * 90}>
      <Card className="h-full p-6">
        <h3 class="text-[length:var(--font-h3)] font-bold tracking-[-0.04em]">{category.name}</h3>
        <div class="mt-5 flex flex-wrap gap-2">
          {category.skills.map((skill) => <Badge>{skill}</Badge>)}
        </div>
      </Card>
    </Reveal>
  ))}
</div>
