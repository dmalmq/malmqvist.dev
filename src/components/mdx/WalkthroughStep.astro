---
import ResponsivePicture from "../ResponsivePicture.astro";
import { getLightboxImagePath } from "../../lib/image-assets.mjs";

interface Props {
  number: number;
  title: string;
  src: string;
  alt: string;
  caption?: string;
}

const { number, title, src, alt, caption } = Astro.props;
---

<li class="list-none">
  <div class="flex items-center gap-2.5">
    <span class="font-mono text-sm text-[var(--color-text-secondary)]">
      {String(number).padStart(2, "0")}
    </span>
    <p class="text-lg font-semibold text-[var(--color-text-heading)]">
      {title}
    </p>
  </div>
  <button
    type="button"
    data-lightbox-src={getLightboxImagePath(src)}
    class="group mt-4 block w-full overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-secondary)]"
  >
    <ResponsivePicture
      src={src}
      alt={alt}
      sizes="(min-width: 1024px) 85rem, 100vw"
      loading="lazy"
      class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.005]"
    />
  </button>
  {
    caption && (
      <p class="mt-3 max-w-[56rem] text-sm leading-6 text-[var(--color-text-secondary)]">
        {caption}
      </p>
    )
  }
</li>
