---
import type { CollectionEntry } from "astro:content";
import type { Language } from "../i18n/utils";
import CTASection from "./CTASection.astro";
import FadeIn from "./ui/FadeIn.astro";
import Tag from "./ui/Tag.astro";

interface Props {
  lang: Language;
  project: CollectionEntry<"projects">;
  Content: any;
  nextProject?: CollectionEntry<"projects"> | null;
}

const { lang, project, Content, nextProject } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;
const mediaScopeId = `project-media-${project.id.replaceAll("/", "-")}`;

const facts = [
  project.data.role && { label: isJa ? "役割" : "ROLE", value: project.data.role },
  project.data.context && { label: isJa ? "背景" : "CONTEXT", value: project.data.context },
  project.data.timelineLabel && {
    label: isJa ? "期間" : "TIMELINE",
    value: project.data.timelineLabel,
  },
].filter(Boolean);

const copy = isJa
  ? {
      back: "← Workに戻る",
      nextProjectLabel: "次のプロジェクト",
    }
  : {
      back: "← Back to Work",
      nextProjectLabel: "NEXT PROJECT",
    };

const nextProjectSlug = nextProject
  ? nextProject.id.split("/").pop()?.replace(/\.mdx?$/, "")
  : null;
---

<div id={mediaScopeId}>
  <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-6 pt-14 md:pt-18">
    <FadeIn>
      <a
        href={`/${lang}/projects`}
        class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-text-secondary)] transition-colors duration-300 hover:text-[var(--color-accent)]"
        style={typeStyle}
      >
        {copy.back}
      </a>
    </FadeIn>

    {
      project.data.category && (
        <FadeIn delay={40}>
          <div class="mt-6">
            <Tag>{project.data.category}</Tag>
          </div>
        </FadeIn>
      )
    }

    <FadeIn delay={80}>
      <h1
        class="mt-6 max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)] font-semibold leading-[0.95] tracking-[-0.03em] text-[var(--color-text-heading)]"
        style={typeStyle}
      >
        {project.data.title}
      </h1>
      <p
        class="mt-6 max-w-3xl text-lg leading-8 text-[var(--color-text-secondary)] md:text-xl"
        style={typeStyle}
      >
        {project.data.description}
      </p>
    </FadeIn>

    {
      facts.length > 0 && (
        <FadeIn delay={110}>
          <div class="mt-8 flex flex-wrap gap-x-14 gap-y-4">
            {facts.map((fact) => (
              <div>
                <p class="font-mono text-[0.6875rem] font-medium tracking-[0.08em] text-[var(--color-text-secondary)]">
                  {fact.label}
                </p>
                <p class="mt-1 text-sm font-medium text-[var(--color-text-heading)]" style={typeStyle}>
                  {fact.value}
                </p>
              </div>
            ))}
          </div>
        </FadeIn>
      )
    }

    {
      project.data.awards.length > 0 && (
        <FadeIn delay={130}>
          <p class="mt-6 flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
            <span aria-hidden="true">🏆</span>
            {project.data.awards.join(" · ")}
          </p>
        </FadeIn>
      )
    }

    {
      project.data.stations.length > 0 && (
        <FadeIn delay={140}>
          <p class="mt-6 flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
            <span aria-hidden="true">📍</span>
            {project.data.stations.join(" · ")}
          </p>
        </FadeIn>
      )
    }
  </section>

  <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-20">
    <FadeIn delay={80}>
      <article class="editorial-prose max-w-[85rem]" style={typeStyle}>
        <Content />
      </article>
    </FadeIn>
  </section>
</div>

{
  nextProject && nextProjectSlug && (
    <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16">
      <FadeIn>
        <a
          href={`/${lang}/projects/${nextProjectSlug}`}
          class="group flex items-center justify-between gap-6 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-8 py-8 transition-all duration-300 hover:border-[var(--color-border-hover)]"
        >
          <div>
            <p class="font-mono text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-secondary)]">
              {copy.nextProjectLabel}
            </p>
            <p
              class="mt-2 text-2xl font-semibold leading-tight tracking-[-0.01em] text-[var(--color-text-heading)] transition-colors group-hover:text-[var(--color-accent)]"
              style={typeStyle}
            >
              {nextProject.data.title}
            </p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--color-text-secondary)] transition-colors group-hover:text-[var(--color-accent)]" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </FadeIn>
    </section>
  )
}

<CTASection lang={lang} />

<script define:vars={{ mediaScopeId }}>
  const mediaScope = document.getElementById(mediaScopeId);
  if (mediaScope) {
    mediaScope.querySelectorAll("[data-lightbox-src]").forEach((node) => {
      node.addEventListener("click", () => {
        const src = node.getAttribute("data-lightbox-src");
        if (src) {
          window.dispatchEvent(
            new CustomEvent("open-lightbox", {
              detail: { src },
            }),
          );
        }
      });
    });
  }
</script>
