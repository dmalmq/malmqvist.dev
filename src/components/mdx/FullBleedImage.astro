---
import ResponsivePicture from "../ResponsivePicture.astro";
import { getLightboxImagePath } from "../../lib/image-assets.mjs";

interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="mdx-media not-prose my-8">
  <button
    type="button"
    data-lightbox-src={getLightboxImagePath(src)}
    class="group block w-full overflow-hidden rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-bg-secondary)] shadow-[0_34px_90px_-56px_rgba(33,31,28,0.3)] dark:shadow-[0_34px_90px_-56px_rgba(0,0,0,0.65)]"
  >
    <ResponsivePicture
      src={src}
      alt={alt}
      sizes="(min-width: 1024px) 68vw, 100vw"
      loading="lazy"
      class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.01]"
    />
  </button>
  {
    caption && (
      <figcaption class="mt-3 text-sm leading-6 text-[var(--color-text-secondary)]">
        {caption}
      </figcaption>
    )
  }
</figure>
