---
import { DEFAULT_SHARE_IMAGE, getShareImagePath } from "../lib/image-assets.mjs";

type JsonLd = Record<string, unknown>;

interface Props {
  title: string;
  description: string;
  lang: "en" | "ja" | "sv";
  ogImage?: string;
  canonical: string;
  alternateEn: string;
  alternateJa: string;
  alternateSv: string;
  jsonLd?: JsonLd;
}

const HOME_OG_SOURCE = "public/og/home.png";
const HOME_OG_PATH = "/og/home.png";
const SITE_URL = "https://malmqvist.dev";

const {
  title,
  description,
  lang,
  ogImage = HOME_OG_SOURCE,
  canonical,
  alternateEn,
  alternateJa,
  alternateSv,
  jsonLd,
} = Astro.props;

const normalizedOgImage = ogImage === HOME_OG_SOURCE ? HOME_OG_PATH : ogImage;
const shareImagePath = getShareImagePath(normalizedOgImage, DEFAULT_SHARE_IMAGE);
const canonicalUrl = new URL(canonical, SITE_URL).toString();
const alternateEnUrl = new URL(alternateEn, SITE_URL).toString();
const alternateJaUrl = new URL(alternateJa, SITE_URL).toString();
const alternateSvUrl = new URL(alternateSv, SITE_URL).toString();
const ogImageUrl = new URL(shareImagePath, SITE_URL).toString();
const jsonLdText = jsonLd ? JSON.stringify(jsonLd).replace(/</g, "\\u003c") : undefined;
const ogLocale = { en: "en_US", ja: "ja_JP", sv: "sv_SE" }[lang];
---

<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="en" href={alternateEnUrl} />
<link rel="alternate" hreflang="ja" href={alternateJaUrl} />
<link rel="alternate" hreflang="sv" href={alternateSvUrl} />
<link rel="alternate" hreflang="x-default" href={alternateEnUrl} />

<meta property="og:type" content="website" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

{jsonLdText && <script type="application/ld+json" set:html={jsonLdText} />}
