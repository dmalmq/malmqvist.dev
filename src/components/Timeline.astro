---
import Card from "./ui/Card.astro";
import ScrollReveal from "./ui/ScrollReveal.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}
const { lang } = Astro.props;

const timelineData = [
  {
    year: "2023 - Present",
    role:
      lang === "ja"
        ? "BIMデジタルツイン・エンジニア"
        : "BIM Digital Twin Engineer",
    company:
      lang === "ja" ? "JRE Consultants (東京)" : "JRE Consultants (Tokyo)",
    desc:
      lang === "ja"
        ? "日本の国土交通省主導の3D都市モデル「PLATEAU」と連携し、詳細な屋内モデリングや都市スケールのデジタルツインを構築。ネイティブなBIMモデルを、Unity等で動作するインタラクティブプラットフォーム向けに変換する堅牢なデータパイプラインを開発。"
        : "Building deep indoor navigation workflows and digital twins by integrating native BIM geometry into the Japanese government-backed PLATEAU 3D city model. Developing custom agentic pipelines to convert and connect complex spatial data formats.",
  },
  {
    year: "2021 - 2023",
    role: lang === "ja" ? "BIMマネージャー" : "BIM Manager",
    company: lang === "ja" ? "Tengbom (ストックホルム)" : "Tengbom (Stockholm)",
    desc:
      lang === "ja"
        ? "ストックホルム・アーランダ空港第5ターミナル拡張プロジェクト（330m規模）において、BIMマネジメントを牽引。複雑なモデルの統合と品質管理を指揮しました。"
        : "Led BIM management for the 330m Terminal 5 expansion at Stockholm Arlanda Airport. Managed weekly model exports, quality control, and served as the key technical resource for the project team.",
  },
  {
    year: "2016 - 2021",
    role:
      lang === "ja"
        ? "建築エンジニア / BIMモデラー"
        : "Architectural Engineer / BIM Modeler",
    company: lang === "ja" ? "Tengbom (ストックホルム)" : "Tengbom (Stockholm)",
    desc:
      lang === "ja"
        ? "受賞歴のある「Ersta Sjukhus（病院）」プロジェクトにおいて、他社のIFCデータからRevitモデルをゼロから再構築。特徴的なファサードシステムのプライマリモデラーを務め、設備・構造との干渉チェックと施工調整を主導しました。"
        : "Rebuilt the entire Revit model from scratch based on an IFC model for the award-winning Ersta Sjukhus hospital. Served as primary modeler for the complex facade system, leading interdisciplinary coordination and fabrication meetings.",
  },
];
---

<div class="relative pl-8">
  <div class="absolute left-0 top-0 bottom-0 w-px bg-[var(--color-accent)]/30"></div>
  <div class="space-y-4">
    {
      timelineData.map((item, i) => (
        <ScrollReveal variant="slide-right" delay={i * 120}>
          <div class="relative">
            <div class="absolute -left-8 top-7 h-2.5 w-2.5 -translate-x-[calc(50%-0.5px)] rounded-full border-2 border-[var(--color-accent)] bg-[var(--color-bg-primary)]"></div>
            <Card class="p-4 md:p-5">
              <div class="grid gap-6 md:grid-cols-[12rem_minmax(0,1fr)] md:gap-8">
                <div>
                  <p class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-secondary)]">
                    {item.year}
                  </p>
                  <p
                    class="mt-4 text-sm font-semibold leading-7 text-[var(--color-accent)]"
                    style={
                      lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""
                    }
                  >
                    {item.company}
                  </p>
                </div>
                <div>
                  <h3
                    class="text-xl font-semibold leading-tight text-[var(--color-text-heading)] md:text-2xl"
                    style={
                      lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""
                    }
                  >
                    {item.role}
                  </h3>
                  <p
                    class="mt-4 text-base leading-8 text-[var(--color-text-secondary)]"
                    style={
                      lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""
                    }
                  >
                    {item.desc}
                  </p>
                </div>
              </div>
            </Card>
          </div>
        </ScrollReveal>
      ))
    }
  </div>
</div>
