---
import HomePage from "../../components/HomePage.astro";
import Seo from "../../components/Seo.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const description = "東京を拠点に、スウェーデンの受賞歴ある病院・空港プロジェクトから日本のデジタルツインナビゲーションまでをつなぐBIM Manager & Agentic Programmer。";
---

<BaseLayout
  title="Daniel Malmqvist | 建築エンジニア / BIMツール開発"
  description={description}
  image="/og/home.png"
  lang="ja"
>
  <Seo
    slot="head"
    title="Daniel Malmqvist | 建築エンジニア / BIMツール開発"
    description={description}
    lang="ja"
    canonical="/ja/"
    alternateEn="/en/"
    alternateJa="/ja/"
    alternateSv="/sv/"
  />
  <HomePage lang="ja" />
</BaseLayout>
