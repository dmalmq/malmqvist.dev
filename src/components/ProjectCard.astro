---
import { type Language } from "../i18n/utils";
import ResponsivePicture from "./ResponsivePicture.astro";

interface Props {
  project: any;
  lang: Language;
  accentColor?: string;
}

const { project, lang, accentColor = "var(--color-pine)" } = Astro.props;

const slugParts = project.id.split("/");
const slugRoute = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
const url = `/${lang}/projects/${slugRoute}`;
const viewText = lang === "ja" ? "詳細を見る" : "View Project";
---

<a
  href={url}
  class="group block overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] shadow-[0_16px_48px_-36px_rgba(87,82,121,0.42)] transition-all duration-300 hover:border-[var(--color-border-hover)] card-hover-lift"
>
  <!-- Colored accent stripe at top -->
  <div class="h-[3px] w-full" style={`background: ${accentColor};`}></div>

  {
    project.data.coverImage ? (
      <div class="relative w-full aspect-[4/3] overflow-hidden border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]">
        <ResponsivePicture
          src={project.data.coverImage}
          alt={project.data.title}
          sizes="(min-width: 1280px) 28vw, (min-width: 768px) 45vw, 100vw"
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/30 to-transparent transition-opacity duration-300 group-hover:opacity-70"></div>
        {/* "View Project" text reveal on hover */}
        <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <span class="rounded-full bg-[var(--color-bg-primary)]/90 px-5 py-2.5 text-sm font-semibold text-[var(--color-accent)] shadow-lg backdrop-blur-sm">
            {viewText}
          </span>
        </div>
      </div>
    ) : (
      <div class="flex aspect-[4/3] w-full items-center justify-center border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]">
        <span class="font-mono text-sm text-[var(--color-text-secondary)] opacity-50 transition-colors group-hover:text-[var(--color-accent)]">
          // missing visual
        </span>
      </div>
    )
  }

  <div class="p-4 md:p-5">
    <div class="flex flex-wrap gap-2 mb-4 transition-transform duration-300 group-hover:-translate-y-0.5">
      {
        project.data.tags
          .slice(0, 3)
          .map((tag: string) => (
            <span class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1.5 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-secondary)]">
              {tag}
            </span>
          ))
      }
    </div>

    <h3
      class="mb-3 text-2xl font-semibold leading-[1.05] tracking-[-0.04em] text-[var(--color-text-heading)] transition-colors group-hover:text-[var(--color-accent)]"
    >
      {project.data.title}
    </h3>
    <p class="text-base leading-8 text-[var(--color-text-secondary)]">
      {project.data.description}
    </p>
  </div>
</a>
