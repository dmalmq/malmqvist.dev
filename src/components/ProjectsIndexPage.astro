---
import type { CollectionEntry } from "astro:content";
import CTASection from "./CTASection.astro";
import ProjectCard from "./ProjectCard.astro";
import ScrollReveal from "./ui/ScrollReveal.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
  allProjects: CollectionEntry<"projects">[];
}

const { lang, allProjects } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const copy = isJa
  ? {
      eyebrow: "SELECTED WORK",
      title: "プロジェクト",
      description:
        "建築の実務、BIM運用、空間データ変換、自動化をまたぐ仕事をまとめています。単なる成果物一覧ではなく、どのように複雑な情報を扱い、実装へつなげたかを示すページです。",
      filterAll: "すべて",
      filterPractice: "実務",
      filterTools: "ツール",
      filterDigitalTwin: "デジタルツイン",
    }
  : {
      eyebrow: "SELECTED WORK",
      title: "Projects",
      description:
        "A working selection of projects across architecture, BIM operations, spatial-data conversion, and automation. The emphasis is on how complex information becomes usable systems.",
      filterAll: "All",
      filterPractice: "Practice",
      filterTools: "Tools",
      filterDigitalTwin: "Digital Twin",
    };

const filters = [
  { value: "", label: copy.filterAll },
  { value: "Practice", label: copy.filterPractice },
  { value: "Tools", label: copy.filterTools },
  { value: "Digital Twin", label: copy.filterDigitalTwin },
];
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16 pt-20 md:pb-20">
  <SectionHeading eyebrow={copy.eyebrow} title={copy.title} description={copy.description} style={typeStyle} />
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-16">
  <div class="flex flex-wrap gap-2" data-filter-chips role="group" aria-label={copy.eyebrow}>
    {
      filters.map((filter) => (
        <button type="button" class:list={["ui-pill-button", filter.value === "" && "is-active"]} data-filter-category={filter.value} aria-pressed={filter.value === "" ? "true" : "false"}>
          {filter.label}
        </button>
      ))
    }
  </div>

  <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2" data-filter-grid>
    {
      allProjects.map((project, index) => (
        <div data-filter-item data-project-category={project.data.category || ""}>
          <ScrollReveal variant="fade-up" delay={index * 90}>
            <ProjectCard project={project} lang={lang} />
          </ScrollReveal>
        </div>
      ))
    }
  </div>

  <p class="mt-8 hidden text-center text-sm leading-7 text-[var(--color-text-secondary)]" data-filter-empty style={typeStyle}>
    {isJa ? "該当するプロジェクトがありません。" : "No projects match this category."}
  </p>
</section>

<CTASection lang={lang} />

<script>
  function initProjectFilters() {
    const chipGroup = document.querySelector("[data-filter-chips]");
    const grid = document.querySelector("[data-filter-grid]");
    const emptyState = document.querySelector("[data-filter-empty]");
    if (!chipGroup || !grid) return;

    const chips = Array.from(chipGroup.querySelectorAll("[data-filter-category]"));
    const items = Array.from(grid.querySelectorAll("[data-filter-item]"));

    chipGroup.addEventListener("click", (event) => {
      const chip = event.target && event.target.closest("[data-filter-category]");
      if (!chip) return;

      const category = chip.dataset.filterCategory || "";
      chips.forEach((c) => {
        const active = c === chip;
        c.classList.toggle("is-active", active);
        c.setAttribute("aria-pressed", String(active));
      });

      let visibleCount = 0;
      items.forEach((item) => {
        const matches = category === "" || item.dataset.projectCategory === category;
        item.classList.toggle("hidden", !matches);
        if (matches) visibleCount += 1;
      });
      if (emptyState) emptyState.classList.toggle("hidden", visibleCount > 0);
    });
  }

  initProjectFilters();
  document.addEventListener("astro:after-swap", initProjectFilters);
</script>
