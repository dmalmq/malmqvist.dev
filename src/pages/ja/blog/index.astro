---
import { getCollection } from "astro:content";
import BlogIndexPage from "../../../components/BlogIndexPage.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const allPosts = await getCollection("blog", ({ id }) => {
    return id.startsWith("ja/");
});

allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout title="ブログ | Daniel Malmqvist" lang="ja">
    <BlogIndexPage lang="ja" allPosts={allPosts} />
</BaseLayout>
