---
import LanguageToggle from './LanguageToggle';
import ThemeToggle from './ThemeToggle';
import { useTranslations, type Language } from '../i18n/utils';

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const t = useTranslations(currentLang);
---

<header class="sticky top-0 z-50 w-full border-b border-transparent dark:border-b-transparent light:border-[var(--color-border)] dark:bg-[var(--color-bg-primary)]/80 backdrop-blur-md transition-colors duration-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
      {/* Logo/Monogram */}
      <div class="flex-shrink-0">
        <a href={`/${currentLang}/`} class="text-xl font-bold tracking-tight text-[var(--color-text-heading)] hover:text-[var(--color-accent)] transition-colors">
          DM.
        </a>
      </div>
      
      {/* Desktop Navigation */}
      <nav class="hidden md:flex space-x-8">
        <a href={`/${currentLang}/projects`} class="text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-heading)] transition-colors">
          {t('nav.projects')}
        </a>
        <a href={`/${currentLang}/blog`} class="text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-heading)] transition-colors">
          {t('nav.blog')}
        </a>
        <a href={`/${currentLang}/about`} class="text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-heading)] transition-colors">
          {t('nav.about')}
        </a>
        <a href={`/${currentLang}/contact`} class="text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-text-heading)] transition-colors">
          {t('nav.contact')}
        </a>
      </nav>

      {/* Right side controls */}
      <div class="hidden md:flex items-center space-x-4">
        <LanguageToggle currentLang={currentLang} client:load />
        <ThemeToggle client:load />
      </div>

      {/* Mobile menu button */}
      <div class="flex md:hidden items-center space-x-2">
        <ThemeToggle client:load />
        <LanguageToggle currentLang={currentLang} client:load />
        <button id="mobile-menu-btn" type="button" class="p-2 rounded-md text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-surface)] focus:outline-none" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          {/* Hamburger icon */}
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  {/* Mobile menu slide-in panel */}
  <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-bg-secondary)] border-b border-[var(--color-border)] shadow-lg absolute w-full transition-all">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a href={`/${currentLang}/projects`} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-surface)]">
        {t('nav.projects')}
      </a>
      <a href={`/${currentLang}/blog`} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-surface)]">
        {t('nav.blog')}
      </a>
      <a href={`/${currentLang}/about`} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-surface)]">
        {t('nav.about')}
      </a>
      <a href={`/${currentLang}/contact`} class="block px-3 py-2 rounded-md text-base font-medium text-[var(--color-text-primary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-surface)]">
        {t('nav.contact')}
      </a>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true' || false;
      btn.setAttribute('aria-expanded', !expanded ? 'true' : 'false');
      menu.classList.toggle('hidden');
    });
  }
</script>
