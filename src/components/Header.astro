---
import LanguageToggle from "./LanguageToggle";
import ThemeToggle from "./ThemeToggle";
import { useTranslations, type Language } from "../i18n/utils";

interface Props {
  currentLang: Language;
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;
const t = useTranslations(currentLang);

const navItems = [
  { href: `/${currentLang}/projects/`, label: t("nav.projects") },
  { href: `/${currentLang}/consulting/`, label: t("nav.consulting") },
  { href: `/${currentLang}/about/`, label: t("nav.about") },
  { href: `/${currentLang}/contact/`, label: t("nav.contact") },
];

const normalizedPath = currentPath.endsWith("/") ? currentPath : `${currentPath}/`;
const isActive = (href: string) =>
  normalizedPath === href || normalizedPath.startsWith(href);
---

<header id="site-header" class="site-header sticky top-0 z-50 w-full">
  <div class="container flex h-20 items-center justify-between gap-6">
    <a href={`/${currentLang}/`} class="brand-link group inline-flex items-center gap-3" aria-label="Daniel Malmqvist home">
      <span class="seal">DM</span>
      <span class="hidden min-w-0 flex-col leading-none sm:flex">
        <span class="font-serif text-sm font-medium tracking-normal text-[var(--text)]">Daniel Malmqvist</span>
        <span class="mt-1 text-[length:var(--font-meta)] text-[var(--text-muted)]">Tokyo / Stockholm</span>
      </span>
    </a>

    <nav class="desktop-nav hidden items-center gap-1 rounded-full border border-[var(--line)] bg-[color:color-mix(in_srgb,var(--surface)_76%,transparent)] p-1 lg:flex" aria-label="Primary navigation">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "relative rounded-full px-4 py-2 text-sm font-bold transition-colors duration-200 hover:text-[var(--accent)]",
              isActive(item.href) ? "text-[var(--text)]" : "text-[var(--text-muted)]",
            ]}
          >
            {item.label}
            {isActive(item.href) && <span class="active-dot" aria-hidden="true" />}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2 lg:flex">
      <LanguageToggle currentLang={currentLang} client:idle />
      <ThemeToggle client:idle />
      <a class="icon-link" href="https://github.com/dmalmq" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 2C6.48 2 2 6.58 2 12.26c0 4.53 2.87 8.38 6.84 9.74.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.85.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.99c.85 0 1.7.12 2.5.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.07.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.59.69.49A10.14 10.14 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" /></svg>
      </a>
      <a class="icon-link" href="https://www.linkedin.com/in/daniel-malmqvist-profile/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05a3.75 3.75 0 0 1 3.37-1.85c3.61 0 4.27 2.37 4.27 5.46v6.28ZM5.32 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.78 13.02H3.54V9H7.1v11.45ZM22.23 0H1.76C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.76 24h20.47c.97 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0Z" /></svg>
      </a>
    </div>

  </div>
</header>

<script>
  const updateHeader = () => {
    const header = document.getElementById("site-header");
    if (!header) return;
    header.classList.toggle("is-scrolled", window.scrollY > 80);
  };

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
  document.addEventListener("astro:page-load", updateHeader);
</script>

<style>
  .site-header {
    border-bottom: 1px solid transparent;
    background: transparent;
    transition: background-color 200ms ease, border-color 200ms ease, backdrop-filter 200ms ease;
  }

  .site-header.is-scrolled {
    border-bottom-color: var(--line);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(12px);
  }

  .active-dot {
    position: absolute;
    inset-inline: 1rem;
    bottom: 0.35rem;
    height: 2px;
    border-radius: var(--radius-pill);
    background: var(--accent);
  }

  .icon-link {
    display: inline-grid;
    width: 2.5rem;
    height: 2.5rem;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    color: var(--text-muted);
    transition: border-color 200ms ease, color 200ms ease, transform 200ms ease;
  }

  .icon-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .icon-link svg {
    width: 1.1rem;
    height: 1.1rem;
  }
</style>
