---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  class?: string;
  style?: string;
}

const {
  eyebrow,
  title,
  description,
  class: className = "",
  style,
} = Astro.props;

const hasAside = Astro.slots.has("aside");
---

<div
  class:list={[
    "grid gap-6 md:gap-8",
    hasAside && "xl:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.7fr)] xl:items-center",
    className,
  ]}
>
  <div class="max-w-4xl">
    <p class="eyebrow">
      {eyebrow}
    </p>
    <h1
      class="mt-4 max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)]"
      style={style}
    >
      {title}
    </h1>
    <p
      class="mt-4 max-w-3xl text-lg leading-8 text-[var(--text-muted)] [&_a]:text-[var(--accent)] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:brightness-110 md:text-xl"
      style={style}
      set:html={description}
    />
  </div>

  {hasAside && <div class="xl:justify-self-end"><slot name="aside" /></div>}
</div>
