---
import Button from "./ui/Button.astro";
import Card from "./ui/Card.astro";
import FadeIn from "./ui/FadeIn.astro";
import PageLead from "./ui/PageLead.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import SkillsGrid from "./SkillsGrid.astro";
import Timeline from "./Timeline.astro";
import { useTranslations, type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;
const t = useTranslations(lang);

const copy = isJa
  ? {
      eyebrow: "ABOUT",
      title: t("about.title"),
      description:
        "建築の設計意図、BIMの実務、そして自動化をつなぐ仕事をしています。空間データを正しく理解し、運用可能なシステムに変換することが自分の役割です。",
      statsTitle: "現在の立ち位置",
      stats: [
        { label: "拠点", value: "東京在住" },
        { label: "バックグラウンド", value: "Architecture / BIM Management" },
        { label: "現在の焦点", value: "Digital Twin / Automation" },
      ],
      narrativeTitle: "Background",
      paragraphs: [
        "スウェーデンでの伝統的な建築実務から、現在の東京における都市スケールのデジタルツインまで、一貫して空間をどう構成し、どう扱うかを仕事にしてきました。",
        "Tengbomでは受賞歴のある病院建築や空港拡張に携わり、単なるファイル管理ではなく、実際に施工へつながるBIMモデルの再構築、ファサード調整、他分野との衝突解消を担いました。",
        "その後、既存のAECツールだけでは処理しきれない課題に対して、自分でコードを書き、データ変換や自動化のパイプラインを組む方向へ進みました。今は東京で、建築のネイティブな情報を空間システムへ直接つなげる実装に取り組んでいます。",
      ],
      quote:
        "建築家の意図する緻密な空間と、実装のための技術的データパイプライン。その両方を理解することが、良いBIMシステムの前提だと考えています。",
      skillsEyebrow: "SKILLS",
      experienceEyebrow: "EXPERIENCE",
      skillsDesc:
        "扱う領域は幅広いですが、中心にあるのは建築情報を壊さずに次のシステムへ渡すことです。",
      experienceDesc:
        "建築事務所でのBIM実務から、東京でのデジタルツイン開発へと軸足を移してきました。",
    }
  : {
      eyebrow: "ABOUT",
      title: t("about.title"),
      description:
        "I work where architectural intent, BIM practice, and automation meet. The consistent thread is translating complex spatial information into systems that can actually be used.",
      statsTitle: "Current position",
      stats: [
        { label: "Based", value: "Tokyo" },
        { label: "Background", value: "Architecture / BIM Management" },
        { label: "Current focus", value: "Digital Twin / Automation" },
      ],
      narrativeTitle: "Background",
      paragraphs: [
        "My work spans the path from traditional architectural production in Sweden to city-scale <a href='/en/blog/what-is-a-digital-twin'>digital twin</a> work in Tokyo. The core interest has stayed the same: how space is described, coordinated, and made operational.",
        "At Tengbom, I worked on award-winning healthcare and airport projects, not as a passive file coordinator but as someone rebuilding living BIM models, coordinating complex facade systems, and resolving interdisciplinary issues under real delivery pressure.",
        "Over time, the limits of legacy AEC tooling became too obvious to ignore. That pushed me toward writing code, building conversion pipelines, and treating BIM information as something that should move cleanly into broader spatial systems instead of getting trapped in brittle intermediate steps.",
      ],
      quote:
        "The strongest BIM systems are built by people who understand both the discipline-specific design intent and the technical pipeline required to deploy it.",
      skillsEyebrow: "SKILLS",
      experienceEyebrow: "EXPERIENCE",
      skillsDesc:
        "The toolset is broad, but the goal is consistent: preserve meaningful building information while translating it into the next usable system.",
      experienceDesc:
        "The trajectory runs from BIM-heavy architectural practice in Stockholm to digital-twin implementation work in Tokyo.",
    };
---

<section class="pb-6 pt-8 md:pt-12">
  <FadeIn>
    <PageLead
      eyebrow={copy.eyebrow}
      title={copy.title}
      description={copy.description}
      style={typeStyle}
    >
      <Card slot="aside" class="p-6 md:p-7">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
          {copy.statsTitle}
        </p>
        <dl class="mt-5 space-y-4">
          {
            copy.stats.map((item) => (
              <div class="border-b border-[var(--color-border)] pb-4 last:border-b-0 last:pb-0">
                <dt class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-secondary)]">
                  {item.label}
                </dt>
                <dd class="mt-2 text-sm leading-6 text-[var(--color-text-heading)] md:text-base">
                  {item.value}
                </dd>
              </div>
            ))
          }
        </dl>
      </Card>
    </PageLead>
  </FadeIn>
</section>

<div class="section-divider"></div>
<section class="py-[var(--space-section-lg)]">
  <div class="grid gap-8 xl:grid-cols-[minmax(18rem,22rem)_minmax(0,1fr)] xl:items-start">
    <FadeIn>
      <Card class="overflow-hidden p-0">
        <div class="border-b border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6">
          <div class="group/photo relative overflow-hidden rounded-[1.4rem] ring-2 ring-[var(--color-accent)]/20 ring-offset-4 ring-offset-[var(--color-bg-secondary)]">
            <img
              src="/images/profile-img.JPG"
              alt="Daniel Malmqvist"
              class="aspect-[3/4] w-full object-cover transition-transform duration-500 group-hover/photo:scale-[1.02]"
            />
            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-1/4 bg-gradient-to-t from-black/20 to-transparent"></div>
          </div>
        </div>
        <div class="p-6 md:p-7">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            Daniel Malmqvist
          </p>
          <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
            {isJa
              ? "家族と東京で暮らしながら、建築・BIM・空間データ実装を横断する仕事をしています。"
              : "Based in Tokyo with my family, working across architecture, BIM, and spatial-data implementation."}
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <span class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1.5 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-secondary)]">
              Tokyo
            </span>
            <span class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1.5 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-secondary)]">
              JLPT N3
            </span>
            <span class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-3 py-1.5 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-text-secondary)]">
              EN / SV / 日本語
            </span>
          </div>
        </div>
      </Card>
    </FadeIn>

    <div class="space-y-6">
      <FadeIn delay={70}>
        <Card class="p-5 md:p-6">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            {copy.narrativeTitle}
          </p>
          <div class="mt-5 space-y-5 text-base leading-8 text-[var(--color-text-secondary)] [&_a]:text-[var(--color-accent)] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-[var(--color-accent-hover)] md:text-lg" style={typeStyle}>
            {copy.paragraphs.map((paragraph) => <p set:html={paragraph} />)}
          </div>
          <p class="mt-6 border-l border-[var(--color-border)] pl-4 text-sm leading-7 text-[var(--color-text-heading)] md:text-base" style={typeStyle}>
            {copy.quote}
          </p>
        </Card>
      </FadeIn>

      <FadeIn delay={120}>
        <Card class="p-5 md:p-6">
          <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-2xl">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
                {t("about.resume.title")}
              </p>
              <p class="mt-4 text-base leading-8 text-[var(--color-text-secondary)]" style={typeStyle}>
                {t("about.resume.desc")}
              </p>
            </div>
            <div class="flex flex-wrap gap-3">
              <Button href="/cv/resume-en.pdf" variant={isJa ? "secondary" : "primary"}>
                {t("about.resume.en")}
              </Button>
              <Button href="/cv/resume-jp.pdf" variant={isJa ? "primary" : "secondary"}>
                {t("about.resume.ja")}
              </Button>
            </div>
          </div>
        </Card>
      </FadeIn>
    </div>
  </div>
</section>

<div class="section-divider"></div>
<section class="py-[var(--space-section-md)]">
  <FadeIn>
    <SectionHeading
      eyebrow={copy.skillsEyebrow}
      title={isJa ? "スキル・ツール" : "Skills & tools"}
      description={copy.skillsDesc}
      style={typeStyle}
    />
  </FadeIn>
  <div class="mt-8">
    <FadeIn delay={100}>
      <SkillsGrid lang={lang} />
    </FadeIn>
  </div>
</section>

<div class="section-divider"></div>
<section class="py-[var(--space-section-md)]">
  <FadeIn>
    <SectionHeading
      eyebrow={copy.experienceEyebrow}
      title={isJa ? "職歴" : "Experience"}
      description={copy.experienceDesc}
      style={typeStyle}
    />
  </FadeIn>
  <div class="mt-8">
    <FadeIn delay={100}>
      <Timeline lang={lang} />
    </FadeIn>
  </div>
</section>
