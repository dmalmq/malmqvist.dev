---
import Tag from './ui/Tag.astro';
import { type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}
const { lang } = Astro.props;
const isJa = lang === 'ja';

const skillCategories = [
  {
    name: isJa ? '建築・BIM' : 'Architecture & BIM',
    skills: ['Revit', 'BIM Coordination', 'Clash Detection', 'IFC'],
  },
  {
    name: isJa ? '地理空間' : 'Geospatial',
    skills: ['CityGML', 'GeoPackage', 'IMDF', 'Shapefiles', 'PLATEAU'],
  },
  {
    name: isJa ? 'プログラミング' : 'Programming',
    skills: ['Python', 'C#', 'TypeScript'],
  },
  {
    name: isJa ? 'ビジュアライゼーション' : 'Visualization',
    skills: ['FBX', 'Unity', 'Blender'],
  },
];

const languageSkills = isJa
  ? ['英語 — ネイティブ', 'スウェーデン語 — ネイティブ', '日本語 — JLPT N3']
  : ['English — Native', 'Swedish — Native', 'Japanese — JLPT N3'];
const languagesName = isJa ? '言語' : 'Languages';
const languagesNote = isJa
  ? 'JLPT N3取得済み、N2取得に向けて学習中（2026年7月受験予定）。'
  : 'JLPT N3 certified, currently studying for N2 (scheduled July 2026).';
---

<div class="flex flex-col gap-8">
  {
    skillCategories.map((category) => (
      <div class="flex flex-col gap-3">
        <p class="text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-secondary)]">
          {category.name}
        </p>
        <div class="flex flex-wrap gap-2">
          {category.skills.map((skill) => (
            <Tag>{skill}</Tag>
          ))}
        </div>
      </div>
    ))
  }
  <div class="flex flex-col gap-3">
    <p class="text-[0.78rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-secondary)]">
      {languagesName}
    </p>
    <div class="flex flex-wrap gap-2">
      {languageSkills.map((skill) => (
        <Tag>{skill}</Tag>
      ))}
    </div>
    <p class="text-sm leading-6 text-[var(--color-text-secondary)]">{languagesNote}</p>
  </div>
</div>
