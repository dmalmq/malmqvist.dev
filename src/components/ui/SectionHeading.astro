---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
  style?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = "",
  style,
} = Astro.props;

const alignment =
  align === "center"
    ? "mx-auto items-center text-center"
    : "items-start text-left";
---

<div class={`flex max-w-3xl flex-col ${alignment} ${className}`} style={style}>
  <p class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-bg-secondary)] px-4 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
    {eyebrow}
  </p>
  <h2 class="mt-5 text-[clamp(2.25rem,5vw,3.9rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-[var(--color-text-heading)]">
    {title}
  </h2>
  {
    description && (
      <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--color-text-secondary)] md:text-lg">
        {description}
      </p>
    )
  }
</div>
