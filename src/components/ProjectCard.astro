---
import { type Language } from "../i18n/utils";
import ResponsivePicture from "./ResponsivePicture.astro";

interface Props {
  project: any;
  lang: Language;
  priority?: boolean;
}

const { project, lang, priority = false } = Astro.props;

const slugParts = project.id.split("/");
const slugRoute = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
const url = `/${lang}/projects/${slugRoute}`;
const viewText = { en: "View Project", ja: "詳細を見る", sv: "Visa projekt" }[lang];
---

<div class="project-card">
  <a
    href={url}
    class="group block overflow-hidden rounded-[var(--radius-card)] border border-[var(--line)] bg-[var(--surface)] transition-colors duration-300 hover:border-[var(--accent)] focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
  >
    {
      project.data.coverImage ? (
        <div class="relative w-full aspect-[4/3] overflow-hidden bg-[var(--surface-soft)]">
          <ResponsivePicture
            src={project.data.coverImage}
            alt={project.data.title}
            sizes="(min-width: 1024px) 45vw, (min-width: 640px) 50vw, 100vw"
            loading={priority ? "eager" : "lazy"}
            fetchpriority={priority ? "high" : "auto"}
            aspect="wide"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
          <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <span class="rounded-[var(--radius-pill)] bg-[var(--surface)]/90 px-5 py-2.5 text-sm font-semibold text-[var(--accent)] backdrop-blur-sm">
              {viewText}
            </span>
          </div>
        </div>
      ) : (
        <div
          class="flex aspect-[4/3] w-full items-center justify-center bg-[var(--surface-soft)]"
        >
          <svg
            class="h-12 w-12 opacity-15 text-[var(--text-muted)]"
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
            <circle cx="9" cy="9" r="2" />
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
          </svg>
        </div>
      )
    }

    <div class="p-4 md:p-5">
      <div class="mb-4 flex flex-wrap gap-2">
        {
          project.data.tags.slice(0, 3).map((tag: string) => (
            <span class="inline-flex items-center rounded-[var(--radius-input)] border border-[var(--line)] bg-[var(--surface-soft)] px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-[var(--text-muted)]">
              {tag}
            </span>
          ))
        }
      </div>

      <h3
        class="mb-3 text-2xl leading-[1.05] text-[var(--text)] transition-colors group-hover:text-[var(--accent)]"
      >
        {project.data.title}
      </h3>
      <p class="text-[length:var(--font-body)] leading-8 text-[var(--text-muted)]">
        {project.data.description}
      </p>
    </div>
  </a>
</div>

<style>
  /* Ensure project-card class is present for QA selectors */
  .project-card {
    display: block;
  }
</style>
