---
import type { CollectionEntry } from "astro:content";
import type { Language } from "../i18n/utils";
import BlogPostCard from "./BlogPostCard.astro";
import Button from "./ui/Button.astro";
import FadeIn from "./ui/FadeIn.astro";
import ResponsivePicture from "./ResponsivePicture.astro";
import Tag from "./ui/Tag.astro";

interface Props {
  lang: Language;
  post: CollectionEntry<"blog">;
  Content: any;
  relatedPosts: CollectionEntry<"blog">[];
}

const { lang, post, Content, relatedPosts } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;
const publishDate = post.data.publishDate;
const readingTime = post.data.readingTime;
const topicCount = post.data.tags.length;
const formattedDate = new Intl.DateTimeFormat(isJa ? "ja-JP" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(publishDate);

const copy = isJa
  ? {
      back: "記事一覧に戻る",
      lead: "この記事を読み、関連投稿を見つけ、次のアクションへ進めます。",
      metaTitle: "記事メタ",
      metaItems: [
        { label: "公開日", value: formattedDate },
        { label: "読了時間", value: readingTime || "数分" },
        {
          label: "トピック数",
          value: `${topicCount} 件`,
        },
      ],
      metaNote:
        "記事はプロジェクト実務に近いテーマから順に増やしていきます。技術の断片ではなく、運用に効く考え方を残すための記録です。",
      bodyEyebrow: "ARTICLE",
      bodyTitle: "本文",
      bodyDescription:
        "まず本文で、実装判断の背景と手順を整理して確認します。",
      topicsTitle: "主なトピック",
      nextTitle: "次に見るもの",
      primaryCta: "プロジェクトを見る",
      secondaryCta: "問い合わせる",
      relatedEyebrow: "MORE WRITING",
      relatedTitle: "関連記事",
      relatedDescription:
        "次に、近い課題を扱う関連記事を見つけます。",
    }
  : {
      back: "Back to writing",
      lead: "Read this article, discover related posts, then move to your next action.",
      metaTitle: "Article profile",
      metaItems: [
        { label: "Published", value: formattedDate },
        { label: "Reading time", value: readingTime || "A few minutes" },
        {
          label: "Topics",
          value: `${topicCount}`,
        },
      ],
      metaNote:
        "The writing stays close to practical implementation. The goal is not trend commentary, but reusable technical judgement.",
      bodyEyebrow: "ARTICLE",
      bodyTitle: "The full note",
      bodyDescription:
        "Start with the article to review the implementation decisions and execution details.",
      topicsTitle: "Primary topics",
      nextTitle: "Continue from here",
      primaryCta: "See projects",
      secondaryCta: "Get in touch",
      relatedEyebrow: "MORE WRITING",
      relatedTitle: "Related posts",
      relatedDescription:
        "Then discover related posts that explore similar technical problems.",
    };
---

<div class="blog-post--compact">
  <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pb-6 pt-12 md:pt-16">
  <FadeIn>
    <a
      href={`/${lang}/blog`}
      class="inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-text-secondary)] transition-colors duration-300 hover:text-[var(--color-accent)]"
      style={typeStyle}
    >
      <span aria-hidden="true">←</span>
      {copy.back}
    </a>
  </FadeIn>

  <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(12rem,16rem)] lg:items-start">
    <div class="max-w-4xl">
      <FadeIn delay={60}>
        <h1
          class="text-[clamp(2rem,4.6vw,3.5rem)] font-semibold leading-[0.96] tracking-[-0.05em] text-[var(--color-text-heading)]"
          style={typeStyle}
        >
          {post.data.title}
        </h1>
      </FadeIn>
    </div>

    {
      post.data.coverImage && (
        <FadeIn delay={110}>
          <div class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
            <ResponsivePicture
              src={post.data.coverImage}
              alt={post.data.title}
              sizes="(min-width: 1024px) 16rem, 100vw"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>
        </FadeIn>
      )
    }
  </div>
  </section>

  <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 border-t border-[var(--color-border)] pt-12 md:pt-14">
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.5fr)]">
    <div>
      <FadeIn delay={90}>
        <article class="editorial-prose" style={typeStyle}>
          <Content />
        </article>
      </FadeIn>

      <FadeIn delay={120}>
        <div class="blog-post--compact-intro mt-6">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
            {copy.bodyEyebrow}
          </p>
          <h2 class="mt-4 text-2xl font-semibold tracking-[-0.03em] text-[var(--color-text-heading)]" style={typeStyle}>
            {copy.bodyTitle}
          </h2>
          <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)] md:text-base" style={typeStyle}>
            {copy.bodyDescription}
          </p>
          <p class="mt-4 text-sm leading-7 text-[var(--color-text-secondary)] md:text-base" style={typeStyle}>
            {copy.lead}
          </p>
          <p class="mt-4 border-l border-[var(--color-border)] pl-4 text-sm leading-7 text-[var(--color-text-secondary)]" style={typeStyle}>
            {copy.metaNote}
          </p>
        </div>
      </FadeIn>
    </div>

    <div class="space-y-6 xl:sticky xl:top-28 self-start">
      <FadeIn delay={120}>
        <aside class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-4 shadow-[0_14px_38px_-34px_rgba(87,82,121,0.34)] dark:shadow-[0_14px_38px_-34px_rgba(25,23,36,0.95)]">
          <p class="text-[0.64rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            {copy.metaTitle}
          </p>
          <dl class="mt-4 space-y-3">
            {copy.metaItems.map((item) => (
              <div class="flex items-center justify-between gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-3 py-2">
                <dt class="text-[0.72rem] font-medium uppercase tracking-[0.16em] text-[var(--color-text-secondary)]" style={typeStyle}>
                  {item.label}
                </dt>
                <dd class="text-sm font-semibold text-[var(--color-text-heading)]" style={typeStyle}>
                  {item.value}
                </dd>
              </div>
            ))}
          </dl>
        </aside>
      </FadeIn>

      <FadeIn delay={140}>
        <div class="rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6 shadow-[0_22px_62px_-46px_rgba(87,82,121,0.36)] dark:shadow-[0_22px_62px_-46px_rgba(25,23,36,0.95)] md:p-7">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            {copy.topicsTitle}
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => <Tag>{tag}</Tag>)}
          </div>
        </div>
      </FadeIn>

      <FadeIn delay={190}>
        <div class="rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 shadow-[0_18px_48px_-42px_rgba(87,82,121,0.34)] dark:shadow-[0_18px_48px_-42px_rgba(25,23,36,0.95)] md:p-7">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
            {copy.nextTitle}
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <Button href={`/${lang}/projects`} variant="primary">
              {copy.primaryCta}
            </Button>
            <Button href={`/${lang}/contact`} variant="secondary">
              {copy.secondaryCta}
            </Button>
          </div>
        </div>
      </FadeIn>
    </div>
  </div>
  </section>

{
  relatedPosts.length > 0 && (
    <section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 border-t border-[var(--color-border)] pt-20 md:pt-28">
      <FadeIn>
        <div class="max-w-3xl">
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
            {copy.relatedEyebrow}
          </p>
          <h2
            class="mt-5 text-[clamp(2.2rem,5vw,3.8rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-[var(--color-text-heading)]"
            style={typeStyle}
          >
            {copy.relatedTitle}
          </h2>
          <p class="mt-5 text-base leading-8 text-[var(--color-text-secondary)] md:text-lg" style={typeStyle}>
            {copy.relatedDescription}
          </p>
        </div>
      </FadeIn>

      <div class="mt-10 space-y-4">
        {relatedPosts.map((relatedPost, index) => (
          <FadeIn delay={index * 110}>
            <BlogPostCard post={relatedPost} lang={lang} />
          </FadeIn>
        ))}
      </div>
    </section>
  )
}
</div>
