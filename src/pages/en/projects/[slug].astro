---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectDetailPage from "../../../components/ProjectDetailPage.astro";
import { buildArticleJsonLd } from "../../../lib/seo.mjs";

export const prerender = true;

export async function getStaticPaths() {
    const projects = await getCollection("projects", ({ id }) =>
        id.startsWith("en/"),
    );
    return projects.map((p) => {
        const slugParts = p.id.split("/");
        const basename = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
        return {
            params: { slug: basename },
            props: { project: p },
        };
    });
}

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const relatedProjects = (await getCollection("projects", ({ id }) =>
    id.startsWith("en/"),
))
    .filter((candidate) => candidate.id !== project.id)
    .sort(
        (a, b) =>
            b.data.publishDate.getTime() - a.data.publishDate.getTime(),
    )
    .slice(0, 3);

const jsonLd = buildArticleJsonLd({
    type: "Article",
    title: project.data.title,
    description: project.data.description,
    path: Astro.url.pathname,
    image: project.data.coverImage,
    publishedTime: project.data.publishDate.toISOString(),
    lang: "en",
    keywords: Array.from(new Set([...project.data.tags, ...project.data.techStack])),
});
---

<BaseLayout
    title={`${project.data.title} | Projects`}
    description={project.data.description}
    image={project.data.coverImage}
    ogType="article"
    publishedTime={project.data.publishDate.toISOString()}
    lang="en"
    enableLightbox={true}
>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <ProjectDetailPage
        lang="en"
        project={project}
        Content={Content}
        relatedProjects={relatedProjects}
    />
</BaseLayout>
