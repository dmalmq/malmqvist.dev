---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
  style?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = "",
  style,
} = Astro.props;

const alignment =
  align === "center"
    ? "mx-auto items-center text-center"
    : "items-start text-left";
---

<div class={`flex max-w-3xl flex-col gap-4 ${alignment} ${className}`} style={style}>
  <span class={`h-[6px] w-12 rounded-[3px] bg-[var(--color-accent)] ${align === "center" ? "mx-auto" : ""}`} />
  <p class="font-mono text-[0.6875rem] font-medium uppercase tracking-[0.11em] text-[var(--color-accent)]">
    {eyebrow}
  </p>
  <h2 class="text-[clamp(1.75rem,3.5vw,2.25rem)] font-semibold leading-[1.1] tracking-[-0.015em] text-[var(--color-text-heading)]">
    {title}
  </h2>
  {
    description && (
      <p class="max-w-2xl text-base leading-7 text-[var(--color-text-secondary)]">
        {description}
      </p>
    )
  }
</div>
