---
import Reveal from "./animation/Reveal.astro";
import ResponsivePicture from "./ResponsivePicture.astro";
import AboutSplit from "./sections/AboutSplit.astro";
import CtaBand from "./sections/CtaBand.astro";
import SelectedWork from "./sections/SelectedWork.astro";
import { useTranslations, type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<main class="home-page bg-[var(--bg)] text-[var(--text)]">
  <section class="hero-section relative isolate overflow-hidden bg-[var(--bg)]">
    <div class="container relative grid min-h-[100svh] gap-12 py-[clamp(6rem,10vw,8rem)] lg:grid-cols-[minmax(0,1fr)_minmax(22rem,34rem)] lg:items-center">
      <Reveal>
        <div class="flex flex-col gap-6">
          <span
            class="eyebrow lg:absolute lg:left-0 lg:top-0 lg:[writing-mode:vertical-rl] lg:[text-orientation:mixed]"
            aria-hidden="true"
          >STOCKHOLM → TOKYO</span>
          <h1 class="font-serif" style="font-size: var(--font-hero)">
            {t("hero.tagline")}
          </h1>
          <p class="max-w-2xl text-base leading-8 text-[var(--text-muted)] md:text-lg">
            {t("hero.tagline.desc")}
          </p>
          <div class="mt-2 flex flex-wrap gap-4">
            <a
              href={`/${lang}/contact/`}
              class="inline-flex min-h-11 items-center justify-center rounded-[var(--radius-input)] bg-[var(--accent)] px-6 py-3 text-sm font-bold text-[var(--accent-ink)] transition-transform hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
            >
              {t("hero.cta.primary")}
            </a>
            <a
              href={`/${lang}/projects/`}
              class="inline-flex min-h-11 items-center justify-center rounded-[var(--radius-input)] border border-[var(--line)] px-6 py-3 text-sm font-bold text-[var(--text)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
            >
              {t("hero.cta.secondary")}
            </a>
          </div>
        </div>
      </Reveal>

      <div class="relative mx-auto w-full max-w-xl lg:max-w-none">
        <div class="relative overflow-hidden rounded-[var(--radius-feature)] border border-[var(--line)] bg-[var(--surface)]">
          <ResponsivePicture
            src="/images/_generated/projects__shinjuku-nav-1-optimized-1600w.webp"
            alt="Shinjuku indoor navigation Revit model"
            priority={true}
            aspect="wide"
            sizes="(min-width: 1024px) 34rem, 92vw"
            class="aspect-[4/3] h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <SelectedWork lang={lang} />
  <AboutSplit lang={lang} />
  <CtaBand lang={lang} />
</main>
