---
import Card from './ui/Card.astro';
import Tag from './ui/Tag.astro';
import ScrollReveal from './ui/ScrollReveal.astro';
import { type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}
const { lang } = Astro.props;

const categoryColors = [
  'var(--color-pine)',   // Architecture & BIM
  'var(--color-foam)',   // Geospatial
  'var(--color-iris)',   // Programming
  'var(--color-love)',   // AI & Automation
  'var(--color-gold)',   // Open Source & Viz
  'var(--color-pine)',   // Languages (cycle back)
];

const skillCategories = [
  {
    name: lang === 'ja' ? '建築・BIM' : 'Architecture & BIM',
    icon: 'building',
    skills: ['Revit', 'ArchiCAD', 'BIM Coordination', 'Clash Detection']
  },
  {
    name: lang === 'ja' ? '地理空間・データ' : 'Geospatial & Spatial Data',
    icon: 'globe',
    skills: ['CityGML', 'IFC', 'GeoPackage', 'IMDF', 'Shapefiles']
  },
  {
    name: lang === 'ja' ? 'プログラミング' : 'Programming',
    icon: 'code',
    skills: ['Python', 'TypeScript', 'C#']
  },
  {
    name: lang === 'ja' ? 'AI・自動化' : 'AI & Automation',
    icon: 'sparkles',
    skills: lang === 'ja' ? ['Claude API', 'Agentic Pipelines', 'LLM統合'] : ['Claude API', 'Agentic Pipelines', 'LLM Integration']
  },
  {
    name: lang === 'ja' ? 'オープンソース・CG' : 'Open Source & Viz',
    icon: 'box',
    skills: ['Blender', 'Bonsai', 'Unity', 'FBX']
  },
  {
    name: lang === 'ja' ? '言語' : 'Languages',
    icon: 'message',
    skills: lang === 'ja' ? ['英語 (母語)', 'スウェーデン語 (母語)', '日本語 (JLPT N3)'] : ['English (Native)', 'Swedish (Native)', 'Japanese (JLPT N3)']
  }
];
---
<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:gap-4 lg:grid-cols-3">
  {skillCategories.map((category, i) => (
    <ScrollReveal variant="scale-up" delay={i * 80}>
      <Card class="h-full p-5 md:p-6 card-hover-lift" style={`border-top: 3px solid ${categoryColors[i]};`}>
        <!-- Watermark number -->
        <span class="absolute top-3 right-4 text-5xl font-bold opacity-[0.06] leading-none select-none" aria-hidden="true">
          {String(i + 1).padStart(2, '0')}
        </span>

        <div class="flex items-center gap-3">
          <!-- Icon badge -->
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl"
            style={`background: color-mix(in srgb, ${categoryColors[i]} 12%, transparent); border: 1px solid color-mix(in srgb, ${categoryColors[i]} 20%, transparent);`}
          >
            {category.icon === 'building' && (
              <svg class="h-6 w-6" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
            )}
            {category.icon === 'globe' && (
              <svg class="h-6 w-6" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
            )}
            {category.icon === 'code' && (
              <svg class="h-6 w-6" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            )}
            {category.icon === 'box' && (
              <svg class="h-6 w-6" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            )}
            {category.icon === 'sparkles' && (
              <svg class="h-6 w-6" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
            )}
            {category.icon === 'message' && (
              <svg class="h-6 w-6" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            )}
          </div>
          <h3 class="text-base font-semibold text-[var(--color-text-heading)]">{category.name}</h3>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {category.skills.map(skill => (
            <Tag>{skill}</Tag>
          ))}
        </div>
      </Card>
    </ScrollReveal>
  ))}
</div>
