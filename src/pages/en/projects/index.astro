---
import { getCollection } from "astro:content";
import ProjectsIndexPage from "../../../components/ProjectsIndexPage.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const allProjects = await getCollection("projects", ({ id }) => {
  return id.startsWith("en/");
});

allProjects.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const featuredImage =
  allProjects.find((project) => project.data.featured)?.data.coverImage ??
  allProjects[0]?.data.coverImage ??
  "/images/projects/shinjuku-nav-1.png";
---

<BaseLayout
  title="Projects | Daniel Malmqvist"
  description="Selected case studies across architectural engineering, BIM operations, digital twins, and spatial-data conversion."
  image={featuredImage}
  lang="en"
>
  <ProjectsIndexPage lang="en" allProjects={allProjects} />
</BaseLayout>
