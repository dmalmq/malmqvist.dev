---
import Card from './ui/Card.astro';
import Tag from './ui/Tag.astro';
import { type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}
const { lang } = Astro.props;

const skillCategories = [
  {
    name: lang === 'ja' ? '建築・BIM' : 'Architecture & BIM',
    skills: ['Revit', 'ArchiCAD', 'BIM Coordination', 'Clash Detection']
  },
  {
    name: lang === 'ja' ? '地理空間・データ' : 'Geospatial & Spatial Data',
    skills: ['CityGML', 'IFC', 'GeoPackage', 'IMDF', 'Shapefiles']
  },
  {
    name: lang === 'ja' ? 'プログラミング' : 'Programming',
    skills: ['Python', 'TypeScript', 'C#']
  },
  {
    name: lang === 'ja' ? 'オープンソース・CG' : 'Open Source & Viz',
    skills: ['Blender', 'Bonsai', 'Unity', 'FBX']
  },
  {
    name: lang === 'ja' ? '言語' : 'Languages',
    skills: lang === 'ja' ? ['英語 (母語)', 'スウェーデン語 (母語)', '日本語 (JLPT N3 / N2勉強中)'] : ['English (Native)', 'Swedish (Native)', 'Japanese (JLPT N3, studying for N2)']
  }
];
---
<div class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
  {skillCategories.map(category => (
    <Card class="h-full p-6 md:p-7">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">{lang === 'ja' ? '区分' : 'Category'}</p>
      <h4 class="mt-3 mb-5 text-lg font-semibold text-[var(--color-text-heading)]">{category.name}</h4>
      <div class="flex flex-wrap gap-2">
        {category.skills.map(skill => (
          <Tag>{skill}</Tag>
        ))}
      </div>
    </Card>
  ))}
</div>
