---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<div class="mdx-media not-prose mt-10 max-w-[47.5rem] first:mt-0">
  <p class="font-mono text-[0.6875rem] font-semibold uppercase tracking-[0.11em] text-[var(--color-text-secondary)]">
    {label}
  </p>
  <div class="prose-slot mt-3 text-base leading-7 text-[var(--color-text-secondary)] md:text-lg [&_a]:text-[var(--color-accent)] [&_a]:underline [&_a]:underline-offset-2">
    <slot />
  </div>
</div>
