---
import { getCollection } from "astro:content";
import ProjectsIndexPage from "../../../components/ProjectsIndexPage.astro";
import Seo from "../../../components/Seo.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const allProjects = await getCollection("projects", ({ id }) => {
  return id.startsWith("sv/");
});

allProjects.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const featuredImage =
  allProjects.find((project) => project.data.featured)?.data.coverImage ??
  allProjects[0]?.data.coverImage ??
  "/images/projects/shinjuku-nav-1-optimized.jpg";
---

<BaseLayout
  title="Projekt | Daniel Malmqvist"
  description="Utvalda fallstudier inom arkitekturteknik, BIM-drift, digitala tvillingar och konvertering av spatial data."
  image={featuredImage}
  lang="sv"
>
  <Seo
    slot="head"
    title="Projekt | Daniel Malmqvist"
    description="Utvalda fallstudier inom arkitekturteknik, BIM-drift, digitala tvillingar och konvertering av spatial data."
    lang="sv"
    ogImage={featuredImage}
    canonical="/sv/projects/"
    alternateEn="/en/projects/"
    alternateJa="/ja/projects/"
    alternateSv="/sv/projects/"
  />
  <ProjectsIndexPage lang="sv" allProjects={allProjects} />
</BaseLayout>
