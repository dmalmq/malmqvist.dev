---
import ContactForm from "./ContactForm";
import SocialLinks from "./SocialLinks.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const copy = {
  en: {
    eyebrow: "Contact",
    title: "Get in touch",
    description:
      "Available for conversations around BIM workflows, digital twins, spatial-data conversion, and automation. That can mean project work, technical planning, or just a focused discussion.",
    responseTime: "I usually reply within a few days",
  },
  ja: {
    eyebrow: "お問い合わせ",
    title: "お問い合わせ",
    description:
      "BIMワークフロー、デジタルツイン、空間データの変換、自動化についてのご相談を歓迎しています。案件のご相談、技術的な壁打ちなど、お気軽にどうぞ。",
    responseTime: "通常数日以内に返信します",
  },
  sv: {
    eyebrow: "Kontakt",
    title: "Hör av dig",
    description:
      "Öppen för samtal om BIM-arbetsflöden, digitala tvillingar, spatial datakonvertering och automation. Det kan handla om projektarbete, teknisk planering eller bara en fokuserad diskussion.",
    responseTime: "Jag svarar vanligtvis inom några dagar",
  },
};

const { eyebrow, title, description, responseTime } = copy[lang];
const isJa = lang === "ja";
---

<div class="relative max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pt-8 md:pt-12 pb-[var(--space-8)]">
  <div class="grid gap-10 lg:grid-cols-2 lg:gap-16 items-start">
    {/* Left column — intro */}
    <div class="space-y-6">
      <p class="eyebrow">
        {eyebrow}
      </p>
      <h1
        class="text-4xl text-[var(--text)] sm:text-5xl"
        style={isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined}
      >
        {title}
      </h1>
      <p
        class="text-base leading-8 text-[var(--text-muted)] md:text-lg"
        style={isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined}
      >
        {description}
      </p>
      <p
        class="text-sm text-[var(--accent)] font-medium"
        style={isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined}
      >
        {responseTime}
      </p>

      {/* Social links inline */}
      <div class="pt-2">
        <SocialLinks variant="icons" />
      </div>

      {/* Direct email link */}
      <div class="pt-2">
        <a
          href="mailto:daniel@malmqvist.dev"
          class="inline-flex items-center gap-2 text-sm text-[var(--text-muted)] underline underline-offset-4 decoration-[var(--line)] hover:text-[var(--accent)] hover:decoration-[var(--accent)] transition-colors"
        >
          daniel@malmqvist.dev
        </a>
      </div>
    </div>

    {/* Right column — form */}
    <div class="rounded-[var(--radius-card)] border border-[var(--line)] bg-[var(--surface-soft)] p-6 md:p-8">
      <ContactForm lang={lang} client:only="react" />
    </div>
  </div>
</div>
