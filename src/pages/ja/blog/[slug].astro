---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPostPage from "../../../components/BlogPostPage.astro";

export const prerender = true;

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ id }) => id.startsWith("ja/"));
    return posts.map((p) => {
        const slugParts = p.id.split("/");
        const basename = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
        return {
            params: { slug: basename },
            props: { post: p },
        };
    });
}

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);
const relatedPosts = (await getCollection("blog", ({ id }) =>
    id.startsWith("ja/"),
))
    .filter((candidate) => candidate.id !== post.id)
    .sort(
        (a, b) =>
            b.data.publishDate.getTime() - a.data.publishDate.getTime(),
    )
    .slice(0, 3);
---

<BaseLayout
    title={`${post.data.title} | ブログ`}
    description={post.data.description}
    image={post.data.coverImage}
    ogType="article"
    publishedTime={post.data.publishDate.toISOString()}
    lang="ja"
>
    <BlogPostPage
        lang="ja"
        post={post}
        Content={Content}
        relatedPosts={relatedPosts}
    />
</BaseLayout>
