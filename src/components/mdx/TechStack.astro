---
import Tag from "../ui/Tag.astro";

interface Props {
  label: string;
  items: string[];
}

const { label, items } = Astro.props;
---

<div class="mdx-media not-prose mt-10 max-w-[47.5rem]">
  <p class="font-mono text-[0.6875rem] font-semibold uppercase tracking-[0.11em] text-[var(--color-text-secondary)]">
    {label}
  </p>
  <div class="mt-3 flex flex-wrap gap-2">
    {items.map((item) => <Tag>{item}</Tag>)}
  </div>
</div>
