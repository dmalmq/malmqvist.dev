---
interface Props {
  class?: string;
  [x: string]: any;
}

const { class: className = '', ...rest } = Astro.props;
---

<div
  class={`rounded-[1.6rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] shadow-[0_28px_70px_-48px_rgba(87,82,121,0.42)] transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-border-hover)] hover:shadow-[0_34px_80px_-48px_rgba(87,82,121,0.5)] dark:bg-[var(--color-bg-elevated)] dark:shadow-[0_28px_70px_-48px_rgba(25,23,36,0.95)] ${className}`}
  {...rest}
>
  <slot />
</div>
