---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProjectDetailPage from "../../../components/ProjectDetailPage.astro";

export const prerender = true;

export async function getStaticPaths() {
    const projects = await getCollection("projects", ({ id }) =>
        id.startsWith("ja/"),
    );
    return projects.map((p) => {
        const slugParts = p.id.split("/");
        const basename = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
        return {
            params: { slug: basename },
            props: { project: p },
        };
    });
}

interface Props {
    project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const relatedProjects = (await getCollection("projects", ({ id }) =>
    id.startsWith("ja/"),
))
    .filter((candidate) => candidate.id !== project.id)
    .sort(
        (a, b) =>
            b.data.publishDate.getTime() - a.data.publishDate.getTime(),
    )
    .slice(0, 3);
---

<BaseLayout
    title={`${project.data.title} | プロジェクト`}
    description={project.data.description}
    image={project.data.coverImage}
    ogType="article"
    publishedTime={project.data.publishDate.toISOString()}
    lang="ja"
>
    <ProjectDetailPage
        lang="ja"
        project={project}
        Content={Content}
        relatedProjects={relatedProjects}
    />
</BaseLayout>
