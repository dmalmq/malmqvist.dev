---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FadeIn from "../../components/ui/FadeIn.astro";
import Timeline from "../../components/Timeline.astro";
import Button from "../../components/ui/Button.astro";
import { useTranslations } from "../../i18n/utils";

const t = useTranslations("en");

// SEO JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Daniel Malmqvist",
  url: "https://malmqvist.dev",
  image: "https://malmqvist.dev/images/projects/shinjuku-nav-1.png",
  jobTitle: "BIM Manager & Developer",
  worksFor: [
    {
      "@type": "Organization",
      name: "JRE Consultants",
    },
    {
      "@type": "Organization",
      name: "Tengbom",
    },
  ],
  sameAs: ["https://github.com/dmalmq", "https://linkedin.com/in/dmalmq"],
};
---

<BaseLayout title="About | Daniel Malmqvist" lang="en">
  <!-- Schema.org Script -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <section class="py-16 md:py-24 max-w-4xl mx-auto px-4 md:px-0">
    <FadeIn delay={0}>
      <h1
        class="text-4xl md:text-5xl font-black text-[var(--color-text-heading)] mb-8"
      >
        {t("about.title")}
      </h1>
      <p
        class="text-xl md:text-2xl text-[var(--color-text-secondary)] font-medium leading-relaxed mb-6"
      >
        I bridge the gap between architectural fundamentals, complex BIM
        workflows, and emerging technology.
      </p>
    </FadeIn>

    <div
      class="mt-12 space-y-8 text-lg text-[var(--color-text-secondary)] leading-relaxed"
    >
      <FadeIn delay={100}>
        <p>
          My career spans the full arc of spatial creation. From traditional
          architecture and construction deliverables to cutting-edge city-scale
          digital twins in Tokyo.
        </p>
        <p class="mt-6">
          I started my career at <strong
            class="text-[var(--color-text-primary)]">Tengbom</strong
          >—one of the Nordic region's oldest and most respected architecture
          firms—spending 7 years working on major institutional projects like
          the award-winning Ersta Sjukhus hospital and the 330m Terminal 5
          expansion at Stockholm Arlanda Airport. I didn't just coordinate
          files; I built massive, complex geometry like façade systems from
          scratch, navigating interdisciplinary clash resolutions and tight
          fabrication deadlines.
        </p>
      </FadeIn>

      <FadeIn delay={200}>
        <p>
          Over time, I found the traditional AEC tools lacking. I am an <strong
            class="text-[var(--color-text-primary)]"
            >architect-turned-BIM-manager who learned to code</strong
          >, and that distinction matters. Today I live in Tokyo, developing
          custom tools and agentic pipelines that bypass native legacy data
          conversions, feeding direct building information directly into spatial
          twins like PLATEAU.
        </p>
        <p class="mt-6">
          I believe that the most powerful BIM solutions are built by people who
          genuinely understand both the strict <em
            >architectural design intent</em
          > and the <em>technical data pipeline</em> required to deploy it.
        </p>
      </FadeIn>
    </div>

    <FadeIn delay={300}>
      <div
        class="mt-16 bg-[var(--color-bg-secondary)] border border-[var(--color-border)] rounded-[8px] dark:rounded-[12px] p-6 lg:p-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-6"
      >
        <div>
          <h3 class="text-xl font-bold text-[var(--color-text-heading)] mb-2">
            My Full Resume
          </h3>
          <p class="text-[var(--color-text-secondary)] text-base">
            Comprehensive work history, certifications, and technical
            proficiencies.
          </p>
        </div>
        <Button
          href="/resume-en.pdf"
          variant="primary"
          class="shrink-0"
          download
        >
          {t("about.resume")}
        </Button>
      </div>
    </FadeIn>

    <div class="mt-20">
      <FadeIn delay={400}>
        <h2 class="text-3xl font-bold text-[var(--color-text-heading)] mb-8">
          Experience
        </h2>
        <Timeline lang="en" />
      </FadeIn>
    </div>
  </section>
</BaseLayout>
