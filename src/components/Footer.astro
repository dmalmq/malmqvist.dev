---
import { type Language } from "../i18n/utils";
import SocialLinks from "./SocialLinks.astro";

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const copy = currentLang === "ja"
  ? "建築のディテールから空間システムまでを横断する、建築エンジニア・BIMマネージャー・Agentic Programmer。"
  : "Architectural engineer, BIM manager, and agentic programmer working between architectural detail and spatial systems.";
---

<footer
  class="mt-20 border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)]/80 py-12 transition-colors duration-200"
>
  <div class="mx-auto max-w-[90rem] px-5 sm:px-8 lg:px-10">
    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
          Daniel Malmqvist
        </p>
        <p class="mt-3 max-w-xl text-sm leading-7 text-[var(--color-text-secondary)]">
          {copy}
        </p>
      </div>

      <div class="flex flex-col items-start gap-4 md:items-end">
        <SocialLinks />
        <p class="text-sm text-[var(--color-text-secondary)]">
          &copy; {new Date().getFullYear()} Daniel Malmqvist
        </p>
      </div>
    </div>
  </div>
</footer>
