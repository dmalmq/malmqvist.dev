---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogPostCard from "../../../components/BlogPostCard.astro";
import FadeIn from "../../../components/ui/FadeIn.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ id }) => {
    return id.startsWith("en/");
});

allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout title="Blog | Daniel Malmqvist" lang="en">
    <section class="py-16 md:py-24 max-w-4xl mx-auto px-4 md:px-0">
        <FadeIn delay={0}>
            <h1
                class="text-4xl md:text-5xl font-black text-[var(--color-text-heading)] mb-4"
            >
                Writing
            </h1>
            <p
                class="text-xl text-[var(--color-text-secondary)] font-medium mb-16 max-w-2xl"
            >
                Thoughts on architecture, agentic automation, and building
                better data pipelines for the AEC industry.
            </p>
        </FadeIn>

        <div class="space-y-4">
            {
                allPosts.map((post, i) => (
                    <FadeIn delay={i * 100}>
                        <BlogPostCard post={post} lang="en" />
                    </FadeIn>
                ))
            }
        </div>
    </section>
</BaseLayout>
