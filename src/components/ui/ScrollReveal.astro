---
// ScrollReveal — server HTML is fully visible; the entrance is a progressive
// enhancement. The script applies the variant's initial state only to
// below-viewport elements and only when motion is allowed (JS on, no reduced
// motion, not automated), so content is always complete without it.
interface Props {
  variant?: 'fade-up' | 'fade-in' | 'slide-left' | 'slide-right' | 'scale-up' | 'blur-in';
  delay?: number;
  class?: string;
  once?: boolean;
}

const { variant = 'fade-up', delay = 0, class: className = '', once = true } = Astro.props;
---

<div
  class={`scroll-reveal transition-all duration-700 ease-out ${className}`}
  style={`transition-delay: ${delay}ms;`}
  data-sr-variant={variant}
  data-sr-once={once ? 'true' : 'false'}
>
  <slot />
</div>

<script>
  const variantMap: Record<string, string[]> = {
    'fade-up': ['opacity-0', 'translate-y-8'],
    'fade-in': ['opacity-0'],
    'slide-left': ['opacity-0', '-translate-x-12'],
    'slide-right': ['opacity-0', 'translate-x-12'],
    'scale-up': ['opacity-0', 'scale-95'],
    'blur-in': ['opacity-0', 'blur-sm'],
  };

  const classesFor = (el: Element): string[] =>
    variantMap[el.getAttribute('data-sr-variant') || 'fade-up'] || variantMap['fade-up'];

  const initScrollReveal = () => {
    if (!('IntersectionObserver' in window)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (navigator.webdriver) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.remove(...classesFor(entry.target));
            if (entry.target.getAttribute('data-sr-once') !== 'false') {
              observer.unobserve(entry.target);
            }
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    // Hide and observe only elements below the viewport; above-fold content
    // stays visible from the first paint.
    for (const el of document.querySelectorAll('.scroll-reveal:not(.opacity-0)')) {
      if (el.getBoundingClientRect().top > window.innerHeight * 0.9) {
        el.classList.add(...classesFor(el));
        observer.observe(el);
      }
    }

    setTimeout(() => {
      for (const el of document.querySelectorAll('.scroll-reveal.opacity-0')) {
        el.classList.remove(...classesFor(el));
        observer.unobserve(el);
      }
    }, 4000);
  };

  initScrollReveal();
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
