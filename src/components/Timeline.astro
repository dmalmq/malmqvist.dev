---
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}
const { lang } = Astro.props;
const typeStyle = lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : "";

const timelineData =
  lang === "ja"
    ? [
        {
          date: "2017年 — 2021年",
          role: "建築エンジニア",
          org: "Tengbom・ストックホルム",
          body: "他社から引き継いだIFCファイルをもとにErsta Sjukhusの Revitモデルを再構築し、その後、病院の黄土色アルミファサードシステムのモデリングを主導しました。",
        },
        {
          date: "2021年 — 2024年",
          role: "BIMマネージャー",
          org: "Tengbom・ストックホルム",
          body: "ストックホルム・アーランダ空港の330m規模のターミナル5拡張プロジェクトにおいて、週次のモデルエクスポート管理と納品物の品質管理を担当しました。",
        },
        {
          date: "2024年 — 現在",
          role: "BIMモデラー → デジタルツイン",
          org: "JRE Consultants・東京",
          body: "東京のデジタルツインにおける屋内ナビゲーション可能なレイヤーを構築中。Sta.naviを支えるBIMモデルとデータパイプラインを開発し、日本のPLATEAU 3D都市モデルと統合しています。",
        },
      ]
    : [
        {
          date: "2017 — 2021",
          role: "Architectural Engineer",
          org: "Tengbom · Stockholm",
          body: "Rebuilt the Revit model for Ersta Sjukhus from an inherited IFC file, then led facade modeling for the hospital's ocher-toned aluminum cladding system.",
        },
        {
          date: "2021 — 2024",
          role: "BIM Manager",
          org: "Tengbom · Stockholm",
          body: "Managed weekly model exports and QC'd deliverables on Arlanda Porten, the 330m Terminal 5 expansion at Stockholm Arlanda Airport.",
        },
        {
          date: "2024 — Present",
          role: "BIM Modeler → Digital Twin",
          org: "JRE Consultants · Tokyo",
          body: "Building the indoor navigable layer of Tokyo's digital twin — BIM models and data pipelines behind Sta.navi, integrated with Japan's PLATEAU 3D city model.",
        },
      ];
---

<div class="flex flex-col gap-7">
  {
    timelineData.map((item, i) => (
      <div class="flex items-start gap-5">
        <div class="flex flex-shrink-0 flex-col items-center self-stretch">
          <div class="h-[9px] w-[9px] flex-shrink-0 rounded-full bg-[var(--color-accent)]" />
          {i < timelineData.length - 1 && (
            <div class="mt-[3px] w-[1.5px] flex-1 bg-[var(--color-border-hover)] opacity-35" />
          )}
        </div>
        <div class="flex flex-col gap-1 pb-1">
          <p class="font-mono text-[0.6875rem] font-medium tracking-[0.1em] text-[var(--color-accent)]">
            {item.date}
          </p>
          <h3 class="text-[1.0625rem] font-semibold leading-none text-[var(--color-text-heading)]" style={typeStyle}>
            {item.role}
          </h3>
          <p class="text-sm text-[var(--color-text-secondary)]" style={typeStyle}>
            {item.org}
          </p>
          <p class="max-w-[29rem] text-[0.8125rem] leading-5 text-[var(--color-text-secondary)]" style={typeStyle}>
            {item.body}
          </p>
        </div>
      </div>
    ))
  }
</div>
