---
import type { CollectionEntry } from "astro:content";
import BlogPostCard from "./BlogPostCard.astro";
import ScrollReveal from "./ui/ScrollReveal.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
  allPosts: CollectionEntry<"blog">[];
}

const { lang, allPosts } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const blogColors = ["var(--color-pine)", "var(--color-iris)", "var(--color-love)", "var(--color-gold)", "var(--color-foam)"];

const copy = isJa
  ? {
      eyebrow: "WRITING",
      title: "記事",
      description:
        "建築、BIM、自動化、空間データの実装について書いています。単なる技術メモではなく、実務の現場で何が詰まり、どう設計し直すかを中心にした記録です。",
    }
  : {
      eyebrow: "WRITING",
      title: "Writing",
      description:
        "Notes on architecture, BIM, automation, and spatial-data implementation. The focus is not abstract trend commentary, but how technical decisions actually behave inside real projects.",
    };
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pt-8 md:pt-12 pb-6">
  <div class="space-y-3">
    {allPosts.map((post, index) => (
      <ScrollReveal variant="fade-up" delay={index * 90}>
        <BlogPostCard post={post} lang={lang} accentColor={blogColors[index % blogColors.length]} />
      </ScrollReveal>
    ))}
  </div>
</section>
