---
import Reveal from "./animation/Reveal.astro";
import { Card } from "./ui/card";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const entries = {
  en: [
    { year: "2016 - 2021", company: "Tengbom (Stockholm)", role: "Architect / BIM Modeler", desc: "Rebuilt the Ersta Sjukhus Revit model from IFC and led facade modeling, coordination, and fabrication-ready BIM work." },
    { year: "2021 - 2023", company: "Tengbom (Stockholm)", role: "BIM Manager", desc: "Led BIM delivery for Stockholm Arlanda Airport Terminal 5 expansion, including weekly exports, quality control, and team support." },
    { year: "2023 - 2026", company: "JRE Consultants (Tokyo)", role: "BIM Digital Twin Engineer", desc: "Built indoor-navigation BIM models and spatial data pipelines connected to Japan's PLATEAU 3D city model." },
    { year: "Present", company: "Tokyo", role: "Architecture, BIM, and automation", desc: "Focused on moving native architectural information directly into operational spatial systems." },
  ],
  ja: [
    { year: "2016 - 2021", company: "Tengbom (ストックホルム)", role: "建築エンジニア / BIMモデラー", desc: "Ersta SjukhusのRevitモデルをIFCから再構築し、特徴的なファサードシステムと分野間調整を担当。" },
    { year: "2021 - 2023", company: "Tengbom (ストックホルム)", role: "BIMマネージャー", desc: "ストックホルム・アーランダ空港第5ターミナル拡張で、モデル書き出し、品質管理、BIMサポートを主導。" },
    { year: "2023 - 2026", company: "JRE Consultants (東京)", role: "BIMデジタルツイン・エンジニア", desc: "PLATEAUと連携する屋内ナビゲーション向けに、BIMモデルと空間データ変換パイプラインを構築。" },
    { year: "Present", company: "Tokyo", role: "建築・BIM・自動化", desc: "建築のネイティブな情報を、運用できる空間システムへ直接つなげる実装に注力。" },
  ],
  sv: [
    { year: "2016 - 2021", company: "Tengbom (Stockholm)", role: "Arkitekt / BIM-modellerare", desc: "Byggde upp Ersta Sjukhus Revit-modell från IFC och ledde fasadmodellering, samordning och tillverkningsklar BIM." },
    { year: "2021 - 2023", company: "Tengbom (Stockholm)", role: "BIM-manager", desc: "Ledde BIM-leveransen för utbyggnaden av Stockholm Arlanda Airport Terminal 5, inklusive veckovisa exporter, kvalitetskontroll och teamstöd." },
    { year: "2023 - 2026", company: "JRE Consultants (Tokyo)", role: "BIM Digital Twin Engineer", desc: "Byggde BIM-modeller för inomhusnavigation och spatiala datapipelines kopplade till Japans PLATEAU 3D-stadsmodell." },
    { year: "Present", company: "Tokyo", role: "Arkitektur, BIM och automation", desc: "Fokuserar på att föra arkitekturens nativa information direkt in i operativa spatiala system." },
  ],
}[lang];
---

<div class="relative">
  <div class="absolute bottom-0 left-0 top-0 w-px bg-[var(--line)] md:left-36" aria-hidden="true"></div>
  <div class="space-y-5">
    {entries.map((entry, index) => (
      <Reveal delay={index * 120}>
        <article class="relative grid gap-3 pl-6 md:grid-cols-[9rem_minmax(0,1fr)] md:gap-8 md:pl-0">
          <div class="absolute left-0 top-6 h-3 w-3 -translate-x-1/2 rounded-full border border-[var(--accent)] bg-[var(--bg)] md:left-36" aria-hidden="true"></div>
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--text-muted)] md:pt-6">{entry.year}</p>
          <Card className="p-6">
            <p class="text-sm font-bold text-[var(--accent)]">{entry.company}</p>
            <h3 class="mt-2 text-[length:var(--font-h3)] font-bold tracking-[-0.04em]">{entry.role}</h3>
            <p class="mt-4 text-base leading-8 text-[var(--text-muted)]">{entry.desc}</p>
          </Card>
        </article>
      </Reveal>
    ))}
  </div>
</div>
