---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
  style?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = "",
  style,
} = Astro.props;

const alignment =
  align === "center"
    ? "mx-auto items-center text-center"
    : "items-start text-left";
---

<div class={`flex max-w-3xl flex-col ${alignment} ${className}`} style={style}>
  <p class="eyebrow">
    {eyebrow}
  </p>
  <h2 class="mt-3 text-[clamp(1.75rem,3.5vw,2.75rem)]">
    {title}
  </h2>
  {
    description && (
      <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--text-muted)] md:text-base">
        {description}
      </p>
    )
  }
</div>
