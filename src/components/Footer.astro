---
import { useTranslations, type Language } from "../i18n/utils";
import SocialLinks from "./SocialLinks.astro";

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const t = useTranslations(currentLang);
const year = new Date().getFullYear();
const tagline = {
  en: "BIM, spatial data, and architectural practice in one portfolio.",
  ja: "BIM、空間データ、建築実務をつなぐポートフォリオ。",
  sv: "BIM, spatial data och arkitektur i en portfölj.",
}[currentLang];
const built = "Built with Astro";
const navItems = [
  { href: `/${currentLang}/projects/`, label: t("nav.projects") },
  { href: `/${currentLang}/consulting/`, label: t("nav.consulting") },
  { href: `/${currentLang}/about/`, label: t("nav.about") },
  { href: `/${currentLang}/contact/`, label: t("nav.contact") },
];
---

<footer class="border-t border-[var(--line)] bg-[var(--surface-soft)]/35 py-12 text-[var(--text-muted)]">
  <div class="container grid gap-8 md:grid-cols-[1fr_auto] md:items-start">
    <div>
      <a href={`/${currentLang}/`} class="inline-flex items-center gap-3 text-[var(--text)]" aria-label="Daniel Malmqvist home">
        <span class="seal">DM</span>
        <span class="font-serif font-medium tracking-normal">Daniel Malmqvist</span>
      </a>
      <p class="mt-4 max-w-md text-sm leading-6 text-[var(--text-muted)]">{tagline}</p>
    </div>

    <div class="flex flex-col gap-5 md:items-end">
      <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Footer navigation">
        {navItems.map((item) => (
          <a class="text-sm font-bold text-[var(--text-muted)] transition-colors hover:text-[var(--accent)]" href={item.href}>
            {item.label}
          </a>
        ))}
      </nav>
      <SocialLinks />
    </div>

    <div class="border-t border-[var(--line)] pt-6 text-sm md:col-span-2 md:flex md:items-center md:justify-between">
      <p>&copy; {year} Daniel Malmqvist</p>
      <p class="mt-2 md:mt-0">{built}</p>
    </div>
  </div>
</footer>
