---
import type { CollectionEntry } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import Reveal from "./animation/Reveal.astro";
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
  allProjects: CollectionEntry<"projects">[];
}

const { lang, allProjects } = Astro.props;
const isJa = lang === "ja";
const typeStyle = isJa ? "font-family: 'Noto Sans JP', sans-serif;" : undefined;

const copy = {
  en: {
    eyebrow: "PROJECTS",
    title: "Projects",
    description:
      "A working selection of projects across architecture, BIM operations, spatial-data conversion, and automation.",
  },
  ja: {
    eyebrow: "プロジェクト",
    title: "プロジェクト一覧",
    description:
      "建築の実務、BIM運用、空間データ変換、自動化をまたぐ仕事をまとめています。",
  },
  sv: {
    eyebrow: "PROJEKT",
    title: "Projekt",
    description:
      "Ett urval av projekt inom arkitektur, BIM-drift, spatial datakonvertering och automation.",
  },
}[lang];
---

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 pt-6 md:pt-10 pb-2 md:pb-3">
  <Reveal>
    <div class="max-w-3xl">
      <p class="text-[length:var(--font-meta)] font-semibold uppercase tracking-[0.3em] text-[var(--text-muted)]">
        {copy.eyebrow}
      </p>
      <h1
        class="mt-2 text-[clamp(1.9rem,4vw,3rem)] font-semibold leading-[0.95] tracking-[-0.05em] text-[var(--text)]"
        style={typeStyle}
      >
        {copy.title}
      </h1>
      <p class="mt-3 text-[length:var(--font-body)] leading-7 text-[var(--text-muted)]" style={typeStyle}>
        {copy.description}
      </p>
    </div>
  </Reveal>
</section>

<section class="max-w-[90rem] mx-auto px-5 sm:px-8 lg:px-10 py-6 md:py-8">
  <div data-project-grid class="grid grid-cols-1 gap-8 sm:grid-cols-2">
    {allProjects.map((project, index) => (
      <Reveal delay={index * 90}>
        <ProjectCard project={project} lang={lang} priority={index === 0} />
      </Reveal>
    ))}
  </div>
</section>
