---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="mdx-media not-prose my-8">
  {
    title && (
      <p class="mb-4 text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-[var(--color-text-secondary)]">
        {title}
      </p>
    )
  }
  <ol class="list-none space-y-10">
    <slot />
  </ol>
</div>
