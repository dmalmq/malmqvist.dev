---
import LanguageToggle from "./LanguageToggle";
import ThemeToggle from "./ThemeToggle";
import MagneticButton from "./animation/MagneticButton";
import Button from "./ui/Button.astro";
import { useTranslations, type Language } from "../i18n/utils";

interface Props {
  currentLang: Language;
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;
const t = useTranslations(currentLang);

const navItems = [
  { href: `/${currentLang}/projects`, label: t("nav.projects") },
  { href: `/${currentLang}/about`, label: t("nav.about") },
  { href: `/${currentLang}/blog`, label: t("nav.blog") },
  { href: `/${currentLang}/contact`, label: t("nav.contact") },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-transparent bg-[color:color-mix(in_srgb,var(--color-bg-primary)_82%,transparent)] backdrop-blur-2xl transition-all duration-300"
>
  <div class="mx-auto max-w-[90rem] px-5 sm:px-8 lg:px-10">
    <div class="flex h-[4.5rem] items-center justify-between gap-6">
      <a
        href={`/${currentLang}/`}
        class="group inline-flex min-w-0 flex-shrink items-center gap-3 text-[var(--color-text-heading)] transition-colors"
      >
        <span
          class="flex h-8 w-8 flex-shrink-0 items-center justify-center bg-[var(--color-accent)] font-medium text-[var(--color-accent-foreground)]"
          style="font-family: 'Noto Sans JP', sans-serif;"
          aria-hidden="true"
        >
          朱
        </span>
        <span class="truncate text-base font-semibold tracking-[-0.02em] group-hover:text-[var(--color-accent)]">
          Daniel Malmqvist
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-7">
        {
          navItems.map((item) => {
            const isActive =
              currentPath === item.href ||
              currentPath.startsWith(`${item.href}/`);

            return (
              <a
                href={item.href}
                class:list={[
                  "flex flex-col items-center gap-1 text-[0.9375rem] font-medium transition-colors duration-200",
                  isActive
                    ? "text-[var(--color-accent)]"
                    : "text-[var(--color-text-heading)] hover:text-[var(--color-accent)]",
                ]}
              >
                {item.label}
                <span
                  class:list={[
                    "h-[2px] w-5 rounded-full bg-[var(--color-accent)] transition-opacity duration-200",
                    isActive ? "opacity-100" : "opacity-0",
                  ]}
                />
              </a>
            );
          })
        }
      </nav>

      <div class="hidden md:flex items-center gap-3">
        <ThemeToggle client:idle />
        <LanguageToggle currentLang={currentLang} client:idle />
        <MagneticButton strength={0.2} client:idle>
          <Button href={`/${currentLang}/contact`} variant="primary" class="gap-2 px-4 py-2 text-sm">
            {t("nav.cta")}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </Button>
        </MagneticButton>
      </div>

      <!-- Mobile: compact top bar — brand + theme + language only, no hamburger/CTA -->
      <div class="flex md:hidden flex-shrink-0 items-center gap-3">
        <ThemeToggle client:idle />
        <LanguageToggle currentLang={currentLang} client:idle />
      </div>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    // Header scroll state with gradient border
    const header = document.getElementById("site-header");
    if (header) {
      const onScroll = () => {
        if (window.scrollY > 20) {
          header.classList.add("header-scrolled");
        } else {
          header.classList.remove("header-scrolled");
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    }
  }

  initHeader();
  document.addEventListener("astro:after-swap", initHeader);
</script>
