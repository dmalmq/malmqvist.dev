---
import { type Language } from "../i18n/utils";

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const builtText = currentLang === "ja" ? "ASTRO, REACT & 情熱で構築" : "BUILT WITH ASTRO, REACT & PASSION";
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <div class="mx-auto flex max-w-[90rem] flex-wrap items-center justify-between gap-4 px-5 py-8 sm:px-8 lg:px-10">
    <p class="text-[0.8125rem] text-[var(--color-text-secondary)]">
      &copy; {new Date().getFullYear()} Daniel Malmqvist — Tokyo
    </p>
    <p class="font-mono text-[0.625rem] font-medium uppercase tracking-[0.12em] text-[var(--color-text-secondary)]">
      {builtText}
    </p>
  </div>
</footer>
