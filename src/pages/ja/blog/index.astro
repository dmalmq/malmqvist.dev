---
import { getCollection } from "astro:content";
import BlogIndexPage from "../../../components/BlogIndexPage.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

const allPosts = await getCollection("blog", ({ id }) => {
    return id.startsWith("ja/");
});

allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const shareImage = allPosts[0]?.data.coverImage ?? "/images/projects/shinjuku-nav-1.png";
---

<BaseLayout
    title="ブログ | Daniel Malmqvist"
    description="BIM、自動化、建築エンジニアリング、空間データ実装に関する記事一覧。"
    image={shareImage}
    lang="ja"
>
    <BlogIndexPage lang="ja" allPosts={allPosts} />
</BaseLayout>
