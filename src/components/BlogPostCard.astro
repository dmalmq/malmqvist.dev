---
import { type Language } from "../i18n/utils";

interface Props {
    post: any;
    lang: Language;
}

const { post, lang } = Astro.props;

const slugParts = post.id.split("/");
const slugRoute = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
const url = `/${lang}/blog/${slugRoute}`;

const formattedDate = new Intl.DateTimeFormat("en-CA", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
}).format(post.data.publishDate);

const meta = post.data.readingTime
    ? `${formattedDate} · ${post.data.readingTime.toUpperCase()}`
    : formattedDate;
const tagsLine = post.data.tags.join(" · ").toUpperCase();
---

<a
    href={url}
    class="group flex items-center justify-between gap-6 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] px-6 py-5 transition-all duration-300 hover:border-[var(--color-border-hover)]"
>
    <div class="min-w-0 flex-1">
        <p class="font-mono text-[0.6875rem] font-medium tracking-[0.08em] text-[var(--color-text-secondary)]">
            {meta}
        </p>
        <h3
            class="mt-2 text-[1.375rem] font-semibold leading-tight tracking-[-0.01em] text-[var(--color-text-heading)] transition-colors group-hover:text-[var(--color-accent)]"
            style={lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""}
        >
            {post.data.title}
        </h3>
        <p class="mt-2 font-mono text-[0.6875rem] font-medium tracking-[0.06em] text-[var(--color-text-secondary)]">
            {tagsLine}
        </p>
    </div>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 text-[var(--color-text-secondary)] transition-colors group-hover:text-[var(--color-accent)]" aria-hidden="true">
        <path d="M7 7h10v10" />
        <path d="M7 17 17 7" />
    </svg>
</a>
