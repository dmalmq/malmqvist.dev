---
import ResponsivePicture from "../ResponsivePicture.astro";
import { Badge } from "../ui/badge";
import { Card } from "../ui/card";
import { useTranslations, type Language } from "../../i18n/utils";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const bio = {
  en: "Based in Tokyo with my family, working across architecture, BIM, and spatial-data implementation.",
  ja: "家族と東京で暮らしながら、建築・BIM・空間データ実装を横断する仕事をしています。",
  sv: "Bor i Tokyo med familjen och arbetar över arkitektur, BIM och implementering av spatiala data.",
}[lang];
const jlpt = {
  en: "JLPT N3 passed, N2 in progress (July 2026)",
  ja: "日本語能力試験N3合格、N2取得に向けて勉強中 (2026年7月受験予定)",
  sv: "JLPT N3 avklarad, N2 pågår (juli 2026)",
}[lang];
---

<Card className="overflow-hidden py-0 md:grid md:grid-cols-[minmax(16rem,0.7fr)_minmax(0,1fr)]">
  <div class="bg-[var(--surface-soft)]">
    <ResponsivePicture
      src="/images/_generated/profile-img-709w.webp"
      alt="Daniel Malmqvist"
      sizes="(min-width: 1024px) 28rem, 92vw"
      class="aspect-[4/5] h-full w-full object-cover"
    />
  </div>
  <div class="p-6 md:p-8">
    <p class="eyebrow">Daniel Malmqvist</p>
    <h2 class="mt-3 text-[length:var(--font-h2)]">{t("about.resume.title")}</h2>
    <p class="mt-5 text-base leading-8 text-[var(--text-muted)] md:text-lg">{bio}</p>
    <div class="mt-5 flex flex-wrap gap-2">
      <Badge>Tokyo</Badge>
      <Badge>{jlpt}</Badge>
      <Badge>EN / SV / 日本語</Badge>
    </div>
    <p class="mt-8 text-base leading-8 text-[var(--text-muted)]">{t("about.resume.desc")}</p>
    <div class="mt-5 flex flex-wrap gap-3">
      <a
        href="/cv/resume-en.pdf"
        download
        class="inline-flex min-h-11 items-center justify-center rounded-[var(--radius-input)] bg-[var(--accent)] px-6 py-3 text-sm font-bold text-[var(--accent-ink)] focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
      >
        {t("about.resume.en")}
      </a>
      <a
        href="/cv/resume-jp.pdf"
        download
        class="inline-flex min-h-11 items-center justify-center rounded-[var(--radius-input)] border border-[var(--line)] px-6 py-3 text-sm font-bold text-[var(--text)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)] focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
      >
        {t("about.resume.ja")}
      </a>
    </div>
  </div>
</Card>
