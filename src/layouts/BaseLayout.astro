---
import "../styles/global.css";
import * as transitions from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomNav from "../components/BottomNav.astro";
import ScrollProgress from "../components/animation/ScrollProgress.astro";
import ImageLightbox from "../components/ImageLightbox";
import Fonts from "./fonts.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { useTranslations, type Language } from "../i18n/utils";
import { DEFAULT_SHARE_IMAGE, getShareImagePath } from "../lib/image-assets.mjs";

interface Props {
  title: string;
  description?: string;
  lang: Language;
  image?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  noindex?: boolean;
  enableLightbox?: boolean;
}

const {
  title,
  description = "Daniel Malmqvist — architectural engineer in Tokyo writing Revit plugins, geospatial converters, and BIM data pipelines for digital twin work.",
  lang,
  image = "/images/projects/shinjuku-nav-1-optimized.jpg",
  ogType = "website",
  publishedTime,
  noindex = false,
  enableLightbox = false,
} = Astro.props;

const t = useTranslations(lang);

const currentPath = Astro.url.pathname;
const stripped = currentPath.replace(/^\/(en|ja|sv)(?=\/|$)/, "");
const pathFor = (l: string) => `/${l}${stripped || "/"}`;

const canonicalUrl = new URL(
  currentPath,
  Astro.site ?? "https://malmqvist.dev",
);
const enUrl = new URL(pathFor("en"), Astro.site ?? "https://malmqvist.dev");
const jaUrl = new URL(pathFor("ja"), Astro.site ?? "https://malmqvist.dev");
const svUrl = new URL(pathFor("sv"), Astro.site ?? "https://malmqvist.dev");
const defaultUrl = enUrl;
const shareImagePath = getShareImagePath(image, DEFAULT_SHARE_IMAGE);
const fullImageUrl = new URL(shareImagePath, Astro.site ?? "https://malmqvist.dev");
const AstroRouter = transitions["ClientRouter"];
const hasHeadSlot = Astro.slots.has("head");
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <Fonts />

    {hasHeadSlot ? (
      <slot name="head" />
    ) : (
      <>
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}

        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={fullImageUrl} />
        {publishedTime && <meta property="article:published_time" content={publishedTime} />}

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalUrl} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={fullImageUrl} />

        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="ja" href={jaUrl} />
        <link rel="alternate" hreflang="sv" href={svUrl} />
        <link rel="alternate" hreflang="x-default" href={defaultUrl} />
      </>
    )}

    <script is:inline>
      const applyTheme = (doc = document) => {
        const theme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const useDark = theme === "dark" || (!theme && prefersDark);
        doc.documentElement.classList.toggle("dark", useDark);
      };
      applyTheme();
      document.addEventListener("astro:before-swap", (event) => {
        applyTheme(event.newDocument);
      });
    </script>
    <AstroRouter />
  </head>
  <body
    class="antialiased min-h-screen flex flex-col transition-colors duration-200 overflow-x-hidden"
  >
    <a href="#main-content" class="skip-link">{t("nav.skip")}</a>
    <ScrollProgress />
    <Header currentLang={lang} currentPath={currentPath} transition:animate="none" />

    <main
      id="main-content"
      class="flex-grow w-full"
      tabindex="-1"
      transition:animate="fade"
    >
      <slot />
    </main>

    <Footer currentLang={lang} transition:animate="none" />
    <BottomNav currentLang={lang} currentPath={currentPath} transition:animate="none" />
    {enableLightbox && <ImageLightbox client:idle />}
    <SpeedInsights />
  </body>
</html>
