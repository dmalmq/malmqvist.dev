---
import Card from './ui/Card.astro';
import Tag from './ui/Tag.astro';
import ScrollReveal from './ui/ScrollReveal.astro';
import { type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}
const { lang } = Astro.props;

const categoryColors = [
  'var(--color-pine)',   // Architecture & BIM
  'var(--color-foam)',   // Geospatial
  'var(--color-iris)',   // Programming
  'var(--color-gold)',   // Open Source & Viz
  'var(--color-love)',   // Languages
];

const skillCategories = [
  {
    name: lang === 'ja' ? '建築・BIM' : 'Architecture & BIM',
    icon: 'building',
    skills: ['Revit', 'ArchiCAD', 'BIM Coordination', 'Clash Detection']
  },
  {
    name: lang === 'ja' ? '地理空間・データ' : 'Geospatial & Spatial Data',
    icon: 'globe',
    skills: ['CityGML', 'IFC', 'GeoPackage', 'IMDF', 'Shapefiles']
  },
  {
    name: lang === 'ja' ? 'プログラミング' : 'Programming',
    icon: 'code',
    skills: ['Python', 'TypeScript', 'C#']
  },
  {
    name: lang === 'ja' ? 'オープンソース・CG' : 'Open Source & Viz',
    icon: 'box',
    skills: ['Blender', 'Bonsai', 'Unity', 'FBX']
  },
  {
    name: lang === 'ja' ? '言語' : 'Languages',
    icon: 'message',
    skills: lang === 'ja' ? ['英語 (母語)', 'スウェーデン語 (母語)', '日本語 (JLPT N3)'] : ['English (Native)', 'Swedish (Native)', 'Japanese (JLPT N3)']
  }
];
---
<div class="grid grid-cols-1 gap-3 md:grid-cols-2 md:gap-4 xl:grid-cols-3">
  {skillCategories.map((category, i) => (
    <ScrollReveal variant="scale-up" delay={i * 80}>
      <Card class="h-full p-4 md:p-5" style={`border-left: 3px solid ${categoryColors[i]};`}>
        <div class="flex items-center gap-2.5">
          {category.icon === 'building' && (
            <svg class="h-4 w-4" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
          )}
          {category.icon === 'globe' && (
            <svg class="h-4 w-4" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          )}
          {category.icon === 'code' && (
            <svg class="h-4 w-4" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          )}
          {category.icon === 'box' && (
            <svg class="h-4 w-4" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          )}
          {category.icon === 'message' && (
            <svg class="h-4 w-4" style={`color: ${categoryColors[i]}`} xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
          )}
          <h4 class="text-base font-semibold text-[var(--color-text-heading)]">{category.name}</h4>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {category.skills.map(skill => (
            <Tag>{skill}</Tag>
          ))}
        </div>
      </Card>
    </ScrollReveal>
  ))}
</div>
