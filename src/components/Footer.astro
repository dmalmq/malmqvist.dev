---
import { useTranslations, type Language } from "../i18n/utils";
import SocialLinks from "./SocialLinks.astro";
import MagneticButton from "./animation/MagneticButton";

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const t = useTranslations(currentLang);
const copy = currentLang === "ja"
  ? "建築エンジニアとして、BIMの実務と、空間データを動かすコードのあいだで仕事をしています。"
  : "Architectural engineer working between BIM practice and the code that moves spatial data between tools.";
const backToTopText = currentLang === "ja" ? "トップへ戻る" : "Back to top";
const builtText = currentLang === "ja" ? "Astro + React + 情熱で構築" : "Built with Astro, React & passion";

const navItems = [
  { href: `/${currentLang}/projects`, label: t("nav.projects") },
  { href: `/${currentLang}/blog`, label: t("nav.blog") },
  { href: `/${currentLang}/about`, label: t("nav.about") },
  { href: `/${currentLang}/contact`, label: t("nav.contact") },
];
---

<footer
  class="relative mt-12 border-t border-transparent py-10 transition-colors duration-200 overflow-hidden"
  style="border-image: linear-gradient(to right, transparent, var(--color-accent), transparent) 1; background: linear-gradient(180deg, var(--color-bg-secondary), color-mix(in srgb, var(--color-bg-secondary) 60%, var(--color-bg-primary)));"
>
  <div class="mx-auto max-w-[90rem] px-5 sm:px-8 lg:px-10">
    <div class="grid gap-8 md:grid-cols-[1fr_auto_auto]">
      <div>
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-[var(--color-text-secondary)]">
          Daniel Malmqvist
        </p>
        <p class="mt-1 text-xs font-medium tracking-[0.12em] text-[var(--color-accent)]">
          Tokyo / Stockholm
        </p>
        <p class="mt-3 max-w-xl text-sm leading-7 text-[var(--color-text-secondary)]">
          {copy}
        </p>
        <p class="mt-4 text-xs text-[var(--color-text-secondary)] opacity-60">
          {builtText}
        </p>
      </div>

      <nav class="flex flex-col gap-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="nav-link-underline text-sm font-medium text-[var(--color-text-secondary)] transition-colors duration-200 hover:text-[var(--color-accent)] w-fit"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex flex-col items-start gap-4 md:items-end">
        <SocialLinks />

        <!-- Back to top floating circle with MagneticButton -->
        <MagneticButton strength={0.25} client:idle>
          <button
            id="back-to-top"
            type="button"
            class="inline-flex items-center gap-2.5 justify-center h-14 rounded-full border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-text-secondary)] shadow-[0_16px_40px_-28px_rgba(87,82,121,0.4)] transition-all duration-300 hover:border-[var(--color-border-hover)] hover:text-[var(--color-accent)] hover:-translate-y-1 px-5"
            aria-label={backToTopText}
          >
            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5"/><path d="m5 12 7-7 7 7"/></svg>
            <span class="text-xs font-semibold uppercase tracking-[0.18em]">{backToTopText}</span>
          </button>
        </MagneticButton>

        <p class="text-sm text-[var(--color-text-secondary)]">
          &copy; {new Date().getFullYear()} Daniel Malmqvist
        </p>
      </div>
    </div>
  </div>
</footer>

<script>
  function initFooter() {
    const btn = document.getElementById("back-to-top");
    if (btn) {
      btn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }
  }
  initFooter();
  document.addEventListener("astro:after-swap", initFooter);
</script>
