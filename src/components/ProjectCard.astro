---
import { type Language } from "../i18n/utils";
import ResponsivePicture from "./ResponsivePicture.astro";
import Tag from "./ui/Tag.astro";

interface Props {
  project: any;
  lang: Language;
}

const { project, lang } = Astro.props;

const slugParts = project.id.split("/");
const slugRoute = slugParts[slugParts.length - 1].replace(/\.mdx?$/, "");
const url = `/${lang}/projects/${slugRoute}`;
const readCaseStudyText = lang === "ja" ? "ケーススタディを読む" : "READ CASE STUDY";
---

<a
  href={url}
  class="group block overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] shadow-[0_16px_48px_-36px_rgba(33,31,28,0.28)] transition-all duration-300 hover:border-[var(--color-border-hover)]"
>
  <div class="p-8">
    {
      project.data.coverImage ? (
        <div class="relative w-full aspect-[2/1] overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
          <ResponsivePicture
            src={project.data.coverImage}
            alt={project.data.title}
            sizes="(min-width: 1280px) 28vw, (min-width: 768px) 45vw, 100vw"
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
      ) : (
        <div class="flex aspect-[2/1] w-full items-center justify-center rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
          <svg class="h-10 w-10 opacity-15 text-[var(--color-text-secondary)]" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
      )
    }

    {
      project.data.category && (
        <div class="mt-4">
          <Tag>{project.data.category}</Tag>
        </div>
      )
    }

    <h3 class="mt-4 text-2xl font-semibold leading-tight tracking-[-0.02em] text-[var(--color-text-heading)] transition-colors group-hover:text-[var(--color-accent)]">
      {project.data.title}
    </h3>
    <p class="mt-3 text-sm leading-6 text-[var(--color-text-secondary)]">
      {project.data.description}
    </p>

    <div class="mt-4 flex flex-wrap gap-2">
      {
        project.data.tags.slice(0, 4).map((tag: string) => (
          <Tag>{tag}</Tag>
        ))
      }
    </div>

    <div class="mt-6 inline-flex items-center gap-1.5 text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-accent)]">
      {readCaseStudyText}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </div>
  </div>
</a>
