{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/projects/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/rss\\.xml/?$",
			"dest": "_render"
		},
		{
			"src": "^/en/?$",
			"dest": "_render"
		},
		{
			"src": "^/ja/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/ja/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/ja/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/ja/projects/?$",
			"dest": "_render"
		},
		{
			"src": "^/ja/rss\\.xml/?$",
			"dest": "_render"
		},
		{
			"src": "^/ja/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}