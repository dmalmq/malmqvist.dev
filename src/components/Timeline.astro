---
import { type Language } from "../i18n/utils";

interface Props {
  lang: Language;
}
const { lang } = Astro.props;

const timelineData = [
  {
    year: "2023 - Present",
    role:
      lang === "ja"
        ? "BIMデジタルツイン・エンジニア"
        : "BIM Digital Twin Engineer",
    company:
      lang === "ja" ? "JRE Consultants (東京)" : "JRE Consultants (Tokyo)",
    desc:
      lang === "ja"
        ? "日本の国土交通省主導の3D都市モデル「PLATEAU」と連携し、詳細な屋内モデリングや都市スケールのデジタルツインを構築。ネイティブなBIMモデルを、Unity等で動作するインタラクティブプラットフォーム向けに変換する堅牢なデータパイプラインを開発。"
        : "Building deep indoor navigation workflows and digital twins by integrating native BIM geometry into the Japanese government-backed PLATEAU 3D city model. Developing custom agentic pipelines to convert and connect complex spatial data formats.",
  },
  {
    year: "2021 - 2023",
    role: lang === "ja" ? "BIMマネージャー" : "BIM Manager",
    company: lang === "ja" ? "Tengbom (ストックホルム)" : "Tengbom (Stockholm)",
    desc:
      lang === "ja"
        ? "ストックホルム・アーランダ空港第5ターミナル拡張プロジェクト（330m規模）において、BIMマネジメントを牽引。複雑なモデルの統合と品質管理を指揮しました。"
        : "Led BIM management for the 330m Terminal 5 expansion at Stockholm Arlanda Airport. Managed weekly model exports, quality control, and served as the key technical resource for the project team.",
  },
  {
    year: "2016 - 2021",
    role: lang === "ja" ? "建築設計 / BIMモデラー" : "Architect / BIM Modeler",
    company: lang === "ja" ? "Tengbom (ストックホルム)" : "Tengbom (Stockholm)",
    desc:
      lang === "ja"
        ? "受賞歴のある「Ersta Sjukhus（病院）」プロジェクトにおいて、他社のIFCデータからRevitモデルをゼロから再構築。特徴的なファサードシステムのプライマリモデラーを務め、設備・構造との干渉チェックと施工調整を主導しました。"
        : "Rebuilt the entire Revit model from scratch based on an IFC model for the award-winning Ersta Sjukhus hospital. Served as primary modeler for the complex facade system, leading interdisciplinary coordination and fabrication meetings.",
  },
];
---

<div class="relative border-l border-[var(--color-border)] ml-3 md:ml-6 mt-10">
  {
    timelineData.map((item) => (
      <div class="mb-10 ml-8 md:ml-12 relative">
        <span class="absolute flex items-center justify-center w-4 h-4 rounded-full -left-[39px] md:-left-[55px] ring-4 ring-[var(--color-bg-primary)] bg-[var(--color-accent)]"></span>
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-2 md:gap-4">
          <h3
            class="flex items-center text-lg md:text-xl font-bold text-[var(--color-text-heading)]"
            style={
              lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""
            }
          >
            {item.role}
          </h3>
          <time class="mt-1 md:mt-0 block text-sm font-medium leading-none text-[var(--color-text-secondary)] shrink-0">
            {item.year}
          </time>
        </div>
        <p
          class="mb-4 text-base font-semibold text-[var(--color-accent)]"
          style={
            lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""
          }
        >
          {item.company}
        </p>
        <p
          class="text-base font-normal text-[var(--color-text-secondary)] leading-relaxed"
          style={
            lang === "ja" ? "font-family: 'Noto Sans JP', sans-serif;" : ""
          }
        >
          {item.desc}
        </p>
      </div>
    ))
  }
</div>
